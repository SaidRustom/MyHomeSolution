@page "/portfolio"
@page "/"
@layout PortfolioLayout

<PageTitle>@(_portfolio?.Profile?.FullName ?? "Portfolio") — Software Engineer</PageTitle>

@if (_isLoading)
{
    <div class="portfolio-loader">
        <div class="loader-ring">
            <div></div><div></div><div></div><div></div>
        </div>
    </div>
}
else if (_portfolio?.Profile is not null)
{
    var p = _portfolio.Profile;

    @* ═══════════════════════════════════════════ NAVIGATION ═══════════════════════════════════════════ *@
    <nav class="portfolio-nav @(_scrolled ? "nav-scrolled" : "")">
        <div class="nav-inner">
            <a href="#hero" class="nav-logo">
                <span class="logo-bracket">&lt;</span>@(p.FullName.Split(' ')[0])<span class="logo-bracket"> /&gt;</span>
            </a>
            <div class="nav-links @(_menuOpen ? "nav-links-open" : "")">
                <a href="#about" class="nav-link" @onclick="CloseMenu">About</a>
                <a href="#experience" class="nav-link" @onclick="CloseMenu">Experience</a>
                <a href="#projects" class="nav-link" @onclick="CloseMenu">Projects</a>
                <a href="#skills" class="nav-link" @onclick="CloseMenu">Skills</a>
                <a href="#contact" class="nav-link" @onclick="CloseMenu">Contact</a>
                <a href="/login" class="nav-cta" @onclick="CloseMenu">
                    <span class="cta-icon">🔐</span> Sign In
                </a>
            </div>
            <button class="nav-hamburger @(_menuOpen ? "hamburger-open" : "")" @onclick="ToggleMenu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    @* ═══════════════════════════════════════════ HERO ═══════════════════════════════════════════ *@
    <section id="hero" class="hero-section">
        <div class="hero-bg-grid"></div>
        <div class="hero-glow hero-glow-1"></div>
        <div class="hero-glow hero-glow-2"></div>

        <div class="hero-content">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                Available for opportunities
            </div>

            <h1 class="hero-title">
                Hi, I'm <span class="hero-name">@p.FullName</span>
            </h1>

            <p class="hero-headline">@p.Headline</p>
            <p class="hero-sub">@p.SubHeadline</p>

            <div class="hero-actions">
                <a href="#projects" class="btn-primary">
                    <span>View My Work</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M7 17L17 7M17 7H7M17 7V17"/>
                    </svg>
                </a>
                <a href="Resume.pdf" target="_blank" rel="noopener" class="btn-resume">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                    <span>View Resume</span>
                </a>
                <a href="#contact" class="btn-secondary">
                    <span>Get in Touch</span>
                </a>
            </div>

            <div class="hero-social">
                @if (!string.IsNullOrWhiteSpace(p.GitHubUrl))
                {
                    <a href="@p.GitHubUrl" target="_blank" rel="noopener" class="social-link" title="GitHub">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(p.LinkedInUrl))
                {
                    <a href="@p.LinkedInUrl" target="_blank" rel="noopener" class="social-link" title="LinkedIn">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(p.TwitterUrl))
                {
                    <a href="@p.TwitterUrl" target="_blank" rel="noopener" class="social-link" title="Twitter/X">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(p.Email))
                {
                    <a href="mailto:@p.Email" class="social-link" title="Email">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    </a>
                }
            </div>
        </div>

        <div class="scroll-indicator">
            <div class="scroll-mouse">
                <div class="scroll-wheel"></div>
            </div>
            <span>Scroll to explore</span>
        </div>
    </section>

    @* ═══════════════════════════════════════════ ABOUT ═══════════════════════════════════════════ *@
    <section id="about" class="section about-section">
        <div class="section-container">
            <div class="section-label">
                <span class="label-number">01</span>
                <span class="label-line"></span>
                <span>About Me</span>
            </div>
            <div class="about-grid">
                <div class="about-text">
                    <h2 class="section-title">Crafting digital experiences with <span class="text-gradient">passion & precision</span></h2>
                    @foreach (var paragraph in p.Bio.Split("\n\n", StringSplitOptions.RemoveEmptyEntries))
                    {
                        <p class="about-paragraph">@paragraph</p>
                    }
                </div>
                <div class="about-stats">
                    @if (!string.IsNullOrWhiteSpace(p.Location))
                    {
                        <div class="stat-card">
                            <div class="stat-icon">📍</div>
                            <div class="stat-label">Based in</div>
                            <div class="stat-value">@p.Location</div>
                        </div>
                    }
                    <div class="stat-card">
                        <div class="stat-icon">💼</div>
                        <div class="stat-label">Experience</div>
                        <div class="stat-value">@(_portfolio.Experiences.Count)+ roles</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">🚀</div>
                        <div class="stat-label">Projects</div>
                        <div class="stat-value">@(_portfolio.Projects.Count)+ Multiple end-to-end systems delivered</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">⚡</div>
                        <div class="stat-label">Technologies</div>
                        <div class="stat-value">@(_portfolio.Skills.Count)+ technologies used in production and personal projects</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ═══════════════════════════════════════════ EXPERIENCE ═══════════════════════════════════════════ *@
    @if (_portfolio.Experiences.Count > 0)
    {
        <section id="experience" class="section experience-section">
            <div class="section-container">
                <div class="section-label">
                    <span class="label-number">02</span>
                    <span class="label-line"></span>
                    <span>Experience</span>
                </div>
                <h2 class="section-title">Where I've <span class="text-gradient">made an impact</span></h2>

                <div class="timeline">
                    @foreach (var exp in _portfolio.Experiences)
                    {
                        <div class="timeline-item">
                            <div class="timeline-marker">
                                <div class="marker-dot @(exp.IsCurrent ? "marker-current" : "")"></div>
                                <div class="marker-line"></div>
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <div>
                                        <h3 class="timeline-role">@exp.Role</h3>
                                        <div class="timeline-company">
                                            @if (!string.IsNullOrWhiteSpace(exp.CompanyUrl))
                                            {
                                                <a href="@exp.CompanyUrl" target="_blank" rel="noopener">@exp.Company ↗</a>
                                            }
                                            else
                                            {
                                                @exp.Company
                                            }
                                        </div>
                                    </div>
                                    <div class="timeline-date">
                                        @if (exp.IsCurrent)
                                        {
                                            <span class="current-badge">Current</span>
                                        }
                                        @exp.DateRange
                                    </div>
                                </div>
                                <p class="timeline-description">@exp.Description</p>
                                @if (exp.TechnologyList.Length > 0)
                                {
                                    <div class="timeline-tech">
                                        @foreach (var tech in exp.TechnologyList)
                                        {
                                            <span class="tech-tag">@tech</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    @* ═══════════════════════════════════════════ PROJECTS ═══════════════════════════════════════════ *@
    @if (_portfolio.Projects.Count > 0)
    {
        <section id="projects" class="section projects-section">
            <div class="section-container">
                <div class="section-label">
                    <span class="label-number">03</span>
                    <span class="label-line"></span>
                    <span>Projects</span>
                </div>
                <h2 class="section-title">Things I've <span class="text-gradient">built</span></h2>

                @* Featured projects *@
                @foreach (var project in _portfolio.Projects.Where(p => p.IsFeatured))
                {
                    <div class="featured-project">
                        <div class="project-content">
                            <span class="project-overline">Featured Project</span>
                            <h3 class="project-title">@project.Title</h3>
                            <div class="project-description-card">
                                <p>@(project.LongDescription ?? project.ShortDescription)</p>
                            </div>
                            <div class="project-tech-list">
                                @foreach (var tech in project.TechnologyList)
                                {
                                    <span>@tech</span>
                                }
                            </div>
                            <div class="project-links">
                                @if (!string.IsNullOrWhiteSpace(project.GitHubUrl))
                                {
                                    <a href="@project.GitHubUrl" target="_blank" rel="noopener" title="Source Code">
                                        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(project.LiveUrl))
                                {
                                    <a href="@project.LiveUrl" target="_blank" rel="noopener" title="Live Demo">
                                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }

                @* Other projects grid *@
                @{
                    var otherProjects = _portfolio.Projects.Where(proj => !proj.IsFeatured).ToList();
                }
                @if (otherProjects.Count > 0)
                {
                    <h3 class="other-projects-title">Other Noteworthy Projects</h3>
                    <div class="projects-grid">
                        @foreach (var project in otherProjects)
                        {
                            <div class="project-card">
                                <div class="card-header">
                                    <div class="card-folder">
                                        <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                                    </div>
                                    <div class="card-links">
                                        @if (!string.IsNullOrWhiteSpace(project.GitHubUrl))
                                        {
                                            <a href="@project.GitHubUrl" target="_blank" rel="noopener">
                                                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                                            </a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(project.LiveUrl))
                                        {
                                            <a href="@project.LiveUrl" target="_blank" rel="noopener">
                                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                            </a>
                                        }
                                    </div>
                                </div>
                                <h4 class="card-title">@project.Title</h4>
                                <p class="card-description">@project.ShortDescription</p>
                                <div class="card-tech">
                                    @foreach (var tech in project.TechnologyList)
                                    {
                                        <span>@tech</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    }

    @* ═══════════════════════════════════════════ SKILLS ═══════════════════════════════════════════ *@
    @if (_portfolio.Skills.Count > 0)
    {
        <section id="skills" class="section skills-section">
            <div class="section-container">
                <div class="section-label">
                    <span class="label-number">04</span>
                    <span class="label-line"></span>
                    <span>Skills</span>
                </div>
                <h2 class="section-title">My <span class="text-gradient">tech stack</span></h2>

                <div class="skills-categories">
                    @foreach (var group in _portfolio.Skills.GroupBy(s => s.Category))
                    {
                        <div class="skill-category">
                            <h3 class="category-title">@group.Key</h3>
                            <div class="skill-chips">
                                @foreach (var skill in group)
                                {
                                    <div class="skill-chip" title="Proficiency: @skill.ProficiencyLevel/100">
                                        @if (!string.IsNullOrWhiteSpace(skill.IconClass))
                                        {
                                            <span class="skill-icon">@skill.IconClass</span>
                                        }
                                        <span>@skill.Name</span>
                                        <div class="skill-level">
                                            <div class="skill-level-fill" style="width: @(skill.ProficiencyLevel)%"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    @* ═══════════════════════════════════════════ CONTACT ═══════════════════════════════════════════ *@
    <section id="contact" class="section contact-section">
        <div class="section-container contact-container">
            <div class="section-label">
                <span class="label-number">05</span>
                <span class="label-line"></span>
                <span>Contact</span>
            </div>
            <h2 class="contact-title">Let's work <span class="text-gradient">together</span></h2>
            <p class="contact-subtitle">
                I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.
            </p>
            <a href="mailto:@p.Email" class="btn-primary btn-large">
                <span>Say Hello</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M7 17L17 7M17 7H7M17 7V17"/>
                </svg>
            </a>
        </div>
    </section>

    @* ═══════════════════════════════════════════ FOOTER ═══════════════════════════════════════════ *@
    <footer class="portfolio-footer">
        <div class="footer-inner">
            <div class="footer-social">
                @if (!string.IsNullOrWhiteSpace(p.GitHubUrl))
                {
                    <a href="@p.GitHubUrl" target="_blank" rel="noopener">GitHub</a>
                }
                @if (!string.IsNullOrWhiteSpace(p.LinkedInUrl))
                {
                    <a href="@p.LinkedInUrl" target="_blank" rel="noopener">LinkedIn</a>
                }
                @if (!string.IsNullOrWhiteSpace(p.TwitterUrl))
                {
                    <a href="@p.TwitterUrl" target="_blank" rel="noopener">Twitter</a>
                }
            </div>
            <p class="footer-credit">
                Designed & Built by <strong>@p.FullName</strong>
            </p>
        </div>
    </footer>
}
else
{
    <div class="portfolio-empty">
        <h2>Portfolio Coming Soon</h2>
        <p>Content is being updated. Check back shortly.</p>
        <a href="/login" class="btn-primary"><span>Sign In</span></a>
    </div>
}
