@page "/bills/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@(Bill?.Title ?? "Bill Detail")</PageTitle>

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">

    @if (IsLoading)
    {
        <LoadingIndicator Text="Loading bill details…" />
    }
    else if (Error is not null)
    {
        <ErrorAlert Problem="@Error" OnRetry="LoadBillAsync" />
    }
    else if (Bill is not null)
    {
        <BillDetailPanel Bill="@Bill"
                         OnEdit="@(_canEdit ? EditBillAsync : null)"
                         OnDelete="@(_isOwner ? DeleteBillAsync : null)"
                         OnMarkSplitAsPaid="MarkSplitAsPaidAsync"
                         IsProcessing="@IsProcessing"
                         OnBack="GoBack" />

        <BillPermissionPanel EntityId="@Bill.Id"
                             EntityType="Bill"
                             OwnerId="@Bill.CreatedByUserId"
                             OwnerName="@Bill.CreatedBy"
                             CanEdit="@_isOwner" />
    }
</RadzenStack>
