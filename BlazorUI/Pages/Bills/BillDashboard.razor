@page "/bills/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Bill Dashboard</PageTitle>

<RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem">

    @* Page header *@
    <PageHeader Title="Dashboard" Subtitle="Overview of your shared expenses" Icon="dashboard">
        <Actions>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.375rem">
                <RadzenButton Text="View All Bills" Icon="list" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Secondary" Click="NavigateToBills" />
            </RadzenStack>
        </Actions>
    </PageHeader>

    @if (IsLoading)
    {
        <LoadingIndicator Text="Loading dashboard…" />
    }
    else if (Error is not null)
    {
        <ErrorAlert Problem="@Error" OnRetry="LoadDashboardDataAsync" />
    }
    else
    {
        @* User scope filter bar *@
        <RadzenCard Variant="Variant.Outlined" class="rz-p-3">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Wrap="FlexWrap.Wrap">
                <RadzenIcon Icon="people" Style="color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0"><strong>View:</strong></RadzenText>
                <RadzenSelectBar TValue="UserScopeFilter" @bind-Value="@_userScope" Change="OnUserScopeChangedAsync" Size="ButtonSize.Small">
                    <Items>
                        <RadzenSelectBarItem Text="All Users" Value="UserScopeFilter.All" Icon="groups" />
                        <RadzenSelectBarItem Text="Me Only" Value="UserScopeFilter.MeOnly" Icon="person" />
                    </Items>
                </RadzenSelectBar>
                @if (_userScope == UserScopeFilter.All && ScopeUserOptions.Count > 0)
                {
                    <RadzenDropDown TValue="string?"
                                    Data="@ScopeUserOptions"
                                    @bind-Value="@_selectedScopeUserId"
                                    TextProperty="DisplayName"
                                    ValueProperty="UserId"
                                    AllowClear="true"
                                    Placeholder="Filter by user…"
                                    Style="min-width: 200px;"
                                    Change="@(_ => OnScopeUserChangedAsync())" />
                }
            </RadzenStack>
        </RadzenCard>

        @* Date range selector *@
        <RadzenCard Variant="Variant.Outlined" class="rz-p-3">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Wrap="FlexWrap.Wrap">
                <RadzenIcon Icon="date_range" Style="color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0"><strong>Period:</strong></RadzenText>
                <RadzenDatePicker TValue="DateTimeOffset?" @bind-Value="@FromDate" Placeholder="From" DateFormat="MMM dd, yyyy" Style="width: 170px;" />
                <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">to</RadzenText>
                <RadzenDatePicker TValue="DateTimeOffset?" @bind-Value="@ToDate" Placeholder="To" DateFormat="MMM dd, yyyy" Style="width: 170px;" />
                <RadzenButton Text="Apply" Icon="refresh" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="OnDateRangeChangedAsync" />
            </RadzenStack>
        </RadzenCard>

        @* Analysis filters *@
        @if (Summary is not null)
        {
            <RadzenCard Variant="Variant.Outlined" class="rz-p-3">
                <RadzenStack Orientation="Orientation.Vertical" Gap="0.75rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="filter_list" Style="color: var(--rz-info);" />
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-0"><strong>Analysis Filters</strong></RadzenText>
                        @if (HasAnalysisFilters)
                        {
                            <RadzenButton Text="Clear Filters" Icon="clear" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" Click="ClearAnalysisFilters" />
                        }
                    </RadzenStack>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="0.75rem" Wrap="FlexWrap.Wrap">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="min-width: 220px; flex: 1;">
                            <RadzenLabel Text="Users" />
                            <RadzenDropDown TValue="IEnumerable<string>"
                                           Data="@AvailableUsers"
                                           @bind-Value="@SelectedUserIds"
                                           TextProperty="UserFullName"
                                           ValueProperty="UserId"
                                           Multiple="true"
                                           Chips="true"
                                           AllowClear="true"
                                           Placeholder="All users"
                                           Style="width: 100%;" />
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="min-width: 220px; flex: 1;">
                            <RadzenLabel Text="Bill Categories" />
                            <RadzenDropDown TValue="IEnumerable<BillCategory>"
                                           Data="@AllBillCategories"
                                           @bind-Value="@SelectedBillCategories"
                                           Multiple="true"
                                           Chips="true"
                                           AllowClear="true"
                                           Placeholder="All categories"
                                           Style="width: 100%;" />
                        </RadzenStack>
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>
        }

        @* Spending summary metrics & charts *@
        @if (Summary is not null)
        {
            @* Top-level stat cards *@
            <RadzenRow Gap="1rem" RowGap="1rem">
                <RadzenColumn Size="12" SizeSM="6" SizeLG="3">
                    <StatCard Title="Total Spent" Value="@($"${Summary.TotalSpent:N2}")" Icon="payments" IconColor="var(--rz-primary)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeSM="6" SizeLG="3">
                    <StatCard Title="Owed to You" Value="@($"${Summary.TotalOwed:N2}")" Icon="arrow_downward" IconColor="var(--rz-success)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeSM="6" SizeLG="3">
                    <StatCard Title="You Owe" Value="@($"${Summary.TotalOwing:N2}")" Icon="arrow_upward" IconColor="var(--rz-danger)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeSM="6" SizeLG="3">
                    <StatCard Title="Net Balance"
                              Value="@($"${Math.Abs(Summary.NetBalance):N2}")"
                              Icon="@(Summary.NetBalance >= 0 ? "trending_up" : "trending_down")"
                              IconColor="@(Summary.NetBalance >= 0 ? "var(--rz-success)" : "var(--rz-danger)")"
                              Subtitle="@GetNetBalanceDescription()" />
                </RadzenColumn>
            </RadzenRow>

            @* Charts row *@
            <RadzenRow Gap="1rem" RowGap="1rem">
                <RadzenColumn Size="12" SizeLG="6">
                    <RadzenCard Variant="Variant.Outlined" class="rz-p-4">
                        <CategoryBreakdownChart Data="@FilteredByCategory" />
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeLG="6">
                    <RadzenCard Variant="Variant.Outlined" class="rz-p-4">
                        <UserSpendingChart Data="@FilteredByUser" />
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        }

        @* Balances section *@
        @if (_userScope != UserScopeFilter.MeOnly)
        {
            <RadzenCard Variant="Variant.Outlined" class="rz-p-4">
                <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="account_balance" Style="color: var(--rz-primary);" />
                        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-0"><strong>Balances</strong></RadzenText>
                        @if (!string.IsNullOrEmpty(_selectedScopeUserId))
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" IsPill="true" Variant="Variant.Flat"
                                         Text="@($"Filtered: {ScopeUserOptions.FirstOrDefault(u => u.UserId == _selectedScopeUserId)?.DisplayName ?? _selectedScopeUserId}")" />
                        }
                    </RadzenStack>

                    @if (FilteredBalances.Count == 0)
                    {
                        <EmptyState Icon="account_balance" Title="No balances" Description="You don't have any outstanding balances." />
                    }
                    else
                    {
                        <RadzenRow Gap="1rem" RowGap="1rem">
                            @foreach (var balance in FilteredBalances)
                            {
                                <RadzenColumn Size="12" SizeSM="6" SizeLG="4">
                                    <BalanceCard Balance="@balance" />
                                </RadzenColumn>
                            }
                        </RadzenRow>
                    }
                </RadzenStack>
            </RadzenCard>
        }

        @* Bills tabs — Recently Paid & Upcoming *@
        <RadzenCard Variant="Variant.Outlined" class="rz-p-4">
            <RadzenTabs>
                <Tabs>
                    @* Recently Paid Bills Tab *@
                    <RadzenTabsItem Text="@($"Recently Paid ({PastBills.Count})")" Icon="paid">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem" class="rz-pt-2">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="0.5rem">
                                <RadzenDropDown TValue="RecentBillsFilter"
                                                @bind-Value="@_recentFilter"
                                                Data="@(Enum.GetValues<RecentBillsFilter>())"
                                                Style="width: 180px;">
                                    <Template Context="filter">
                                        @(filter switch
                                        {
                                            RecentBillsFilter.PaidByMe => "Paid by Me",
                                            RecentBillsFilter.PaidByOthers => "Paid by Others",
                                            _ => "All"
                                        })
                                    </Template>
                                    <ValueTemplate Context="filter">
                                        @(filter switch
                                        {
                                            RecentBillsFilter.PaidByMe => "Paid by Me",
                                            RecentBillsFilter.PaidByOthers => "Paid by Others",
                                            _ => "All"
                                        })
                                    </ValueTemplate>
                                </RadzenDropDown>
                                <RadzenButton Text="View All" Icon="arrow_forward" Variant="Variant.Text" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="NavigateToBills" />
                            </RadzenStack>

                            @if (PastBills.Count == 0)
                            {
                                <EmptyState Icon="paid" Title="No recently paid bills" Description="No bills match the selected filter." />
                            }
                            else
                            {
                                <RadzenRow Gap="1rem" RowGap="1rem">
                                    @foreach (var bill in PastBills)
                                    {
                                        <RadzenColumn Size="12" SizeSM="6" SizeLG="4">
                                            <BillCard Bill="@bill" OnView="NavigateToBill" />
                                        </RadzenColumn>
                                    }
                                </RadzenRow>
                            }
                        </RadzenStack>
                    </RadzenTabsItem>

                    @* Upcoming Bills Tab *@
                    <RadzenTabsItem Text="@($"Upcoming ({UpcomingBills.Count})")" Icon="upcoming">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem" class="rz-pt-2">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Wrap="FlexWrap.Wrap">
                                <RadzenDropDown TValue="UpcomingPaidByFilter"
                                                @bind-Value="@_upcomingPaidByFilter"
                                                Data="@(Enum.GetValues<UpcomingPaidByFilter>())"
                                                Style="width: 180px;">
                                    <Template Context="filter">
                                        @(filter switch
                                        {
                                            UpcomingPaidByFilter.Me => "To be paid by: Me",
                                            UpcomingPaidByFilter.Others => "To be paid by: Others",
                                            _ => "To be paid by: All"
                                        })
                                    </Template>
                                    <ValueTemplate Context="filter">
                                        @(filter switch
                                        {
                                            UpcomingPaidByFilter.Me => "To be paid by: Me",
                                            UpcomingPaidByFilter.Others => "To be paid by: Others",
                                            _ => "To be paid by: All"
                                        })
                                    </ValueTemplate>
                                </RadzenDropDown>
                                <RadzenDropDown TValue="UpcomingWithinFilter"
                                                @bind-Value="@_upcomingWithinFilter"
                                                Data="@(Enum.GetValues<UpcomingWithinFilter>())"
                                                Style="width: 180px;">
                                    <Template Context="filter">
                                        @(filter switch
                                        {
                                            UpcomingWithinFilter.Week => "Within: 1 Week",
                                            UpcomingWithinFilter.TwoWeeks => "Within: 2 Weeks",
                                            _ => "Within: 1 Month"
                                        })
                                    </Template>
                                    <ValueTemplate Context="filter">
                                        @(filter switch
                                        {
                                            UpcomingWithinFilter.Week => "Within: 1 Week",
                                            UpcomingWithinFilter.TwoWeeks => "Within: 2 Weeks",
                                            _ => "Within: 1 Month"
                                        })
                                    </ValueTemplate>
                                </RadzenDropDown>
                            </RadzenStack>

                            @if (UpcomingBills.Count == 0)
                            {
                                <EmptyState Icon="upcoming" Title="No upcoming bills" Description="No unpaid bills within the selected timeframe." />
                            }
                            else
                            {
                                <RadzenRow Gap="1rem" RowGap="1rem">
                                    @foreach (var bill in UpcomingBills)
                                    {
                                        <RadzenColumn Size="12" SizeSM="6" SizeLG="4">
                                            <BillCard Bill="@bill" OnView="NavigateToBill" />
                                        </RadzenColumn>
                                    }
                                </RadzenRow>
                            }
                        </RadzenStack>
                    </RadzenTabsItem>
                </Tabs>
            </RadzenTabs>
        </RadzenCard>
    }
</RadzenStack>
