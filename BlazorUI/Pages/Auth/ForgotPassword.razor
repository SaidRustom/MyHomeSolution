@page "/forgot-password"
@using BlazorUI.Models.Auth
@layout AuthLayout

<PageTitle>Forgot Password — MyHome</PageTitle>

<RadzenCard class="auth-card" Style="width: 100%; max-width: 440px; margin: 0 auto;">
    <RadzenStack Gap="1.5rem" Orientation="Orientation.Vertical">

        @if (!EmailSent)
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.25rem">
                <RadzenIcon Icon="lock_reset" Style="font-size: 2.5rem; color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Forgot Password?</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); text-align: center;">
                    Enter your email address and we'll send you a link to reset your password.
                </RadzenText>
            </RadzenStack>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="true"
                             Close="@(() => ErrorMessage = null)" ShowIcon="true">
                    @ErrorMessage
                </RadzenAlert>
            }

            <RadzenTemplateForm TItem="ForgotPasswordRequest" Data="@Model" Submit="@HandleSubmitAsync">
                <RadzenStack Gap="1rem">
                    <RadzenStack Gap="0.25rem">
                        <RadzenLabel Text="Email" Component="ForgotEmail" />
                        <RadzenTextBox Name="ForgotEmail" @bind-Value="Model.Email"
                                       Placeholder="you@example.com" Style="width: 100%;" />
                        <RadzenRequiredValidator Component="ForgotEmail" Text="Email is required." />
                        <RadzenEmailValidator Component="ForgotEmail" Text="Please enter a valid email." />
                    </RadzenStack>

                    <RadzenButton ButtonType="ButtonType.Submit" Text="Send Reset Link" Icon="send"
                                  Style="width: 100%;" IsBusy="@IsLoading" BusyText="Sending…"
                                  ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" />
                </RadzenStack>
            </RadzenTemplateForm>
        }
        else
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="mark_email_read" Style="font-size: 3rem; color: var(--rz-success);" />
                <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Check Your Email</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); text-align: center;">
                    If an account exists with that email address, we've sent a password reset link. Please check your inbox and spam folder.
                </RadzenText>
            </RadzenStack>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                Remember your password?
            </RadzenText>
            <RadzenLink Path="/login" Text="Sign in" Style="font-weight: 500;" />
        </RadzenStack>

    </RadzenStack>
</RadzenCard>
