@page "/confirm-email"
@using BlazorUI.Services.Contracts
@layout AuthLayout

<PageTitle>Verify Email — MyHome</PageTitle>

<RadzenCard class="auth-card" Style="width: 100%; max-width: 480px; margin: 0 auto;">
    <RadzenStack Gap="1.5rem" Orientation="Orientation.Vertical" AlignItems="AlignItems.Center">

        @if (IsLoading)
        {
            <RadzenIcon Icon="hourglass_empty" Style="font-size: 2.5rem; color: var(--rz-primary);" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Verifying Email…</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                Please wait while we verify your email address.
            </RadzenText>
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
        }
        else if (IsSuccess)
        {
            <RadzenIcon Icon="check_circle" Style="font-size: 3rem; color: var(--rz-success);" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Email Verified!</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); text-align: center;">
                Your email address has been confirmed successfully. You can now sign in to your account.
            </RadzenText>
            <RadzenButton Text="Sign In" Icon="login" ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Large" Style="width: 100%;"
                          Click="@(() => Navigation.NavigateTo("/login"))" />
        }
        else
        {
            <RadzenIcon Icon="error_outline" Style="font-size: 3rem; color: var(--rz-danger);" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Verification Failed</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); text-align: center;">
                @ErrorMessage
            </RadzenText>
            <RadzenButton Text="Back to Sign In" Icon="arrow_back" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Large" Style="width: 100%;"
                          Click="@(() => Navigation.NavigateTo("/login"))" />
        }

    </RadzenStack>
</RadzenCard>
