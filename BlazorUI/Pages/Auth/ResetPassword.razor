@page "/reset-password"
@using BlazorUI.Models.Auth
@layout AuthLayout

<PageTitle>Reset Password — MyHome</PageTitle>

<RadzenCard class="auth-card" Style="width: 100%; max-width: 440px; margin: 0 auto;">
    <RadzenStack Gap="1.5rem" Orientation="Orientation.Vertical">

        @if (IsComplete)
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="check_circle" Style="font-size: 3rem; color: var(--rz-success);" />
                <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Password Reset!</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); text-align: center;">
                    Your password has been reset successfully. You can now sign in with your new password.
                </RadzenText>
                <RadzenButton Text="Sign In" Icon="login" ButtonStyle="ButtonStyle.Primary"
                              Size="ButtonSize.Large" Style="width: 100%;"
                              Click="@(() => Navigation.NavigateTo("/login"))" />
            </RadzenStack>
        }
        else if (IsInvalidLink)
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="error_outline" Style="font-size: 3rem; color: var(--rz-danger);" />
                <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Invalid Link</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); text-align: center;">
                    This password reset link is invalid or has expired. Please request a new one.
                </RadzenText>
                <RadzenButton Text="Request New Link" Icon="lock_reset" ButtonStyle="ButtonStyle.Primary"
                              Size="ButtonSize.Large" Style="width: 100%;"
                              Click="@(() => Navigation.NavigateTo("/forgot-password"))" />
            </RadzenStack>
        }
        else
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.25rem">
                <RadzenIcon Icon="lock_reset" Style="font-size: 2.5rem; color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Set New Password</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                    Enter your new password below.
                </RadzenText>
            </RadzenStack>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="true"
                             Close="@(() => ErrorMessage = null)" ShowIcon="true">
                    @ErrorMessage
                </RadzenAlert>
            }

            <RadzenTemplateForm TItem="ResetPasswordRequest" Data="@Model" Submit="@HandleSubmitAsync">
                <RadzenStack Gap="1rem">
                    <RadzenStack Gap="0.25rem">
                        <RadzenLabel Text="New Password" Component="NewPassword" />
                        <RadzenPassword Name="NewPassword" @bind-Value="Model.NewPassword"
                                        Placeholder="Min. 8 characters" Style="width: 100%;" />
                        <RadzenRequiredValidator Component="NewPassword" Text="Password is required." />
                        <RadzenLengthValidator Component="NewPassword" Min="8"
                                               Text="Password must be at least 8 characters." />
                    </RadzenStack>

                    <RadzenStack Gap="0.25rem">
                        <RadzenLabel Text="Confirm Password" Component="ConfirmNewPassword" />
                        <RadzenPassword Name="ConfirmNewPassword" @bind-Value="Model.ConfirmPassword"
                                        Placeholder="Re-enter password" Style="width: 100%;" />
                        <RadzenRequiredValidator Component="ConfirmNewPassword" Text="Please confirm your password." />
                        <RadzenCompareValidator Component="ConfirmNewPassword" Value="@Model.NewPassword"
                                                Text="Passwords do not match." Operator="CompareOperator.Equal" />
                    </RadzenStack>

                    <RadzenButton ButtonType="ButtonType.Submit" Text="Reset Password" Icon="lock_reset"
                                  Style="width: 100%;" IsBusy="@IsLoading" BusyText="Resetting…"
                                  ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" />
                </RadzenStack>
            </RadzenTemplateForm>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                Remember your password?
            </RadzenText>
            <RadzenLink Path="/login" Text="Sign in" Style="font-weight: 500;" />
        </RadzenStack>

    </RadzenStack>
</RadzenCard>
