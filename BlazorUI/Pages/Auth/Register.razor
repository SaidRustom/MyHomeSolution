@page "/register"
@using BlazorUI.Models.Auth
@layout AuthLayout

<PageTitle>Create Account — MyHome</PageTitle>

<RadzenCard class="auth-card" Style="width: 100%; max-width: 480px; margin: 0 auto;">
    <RadzenStack Gap="1.5rem" Orientation="Orientation.Vertical">

        <RadzenStack AlignItems="AlignItems.Center" Gap="0.25rem">
            <RadzenIcon Icon="person_add" Style="font-size: 2.5rem; color: var(--rz-primary);" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Create Account</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                Join MyHome to manage your household
            </RadzenText>
        </RadzenStack>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="true"
                         Close="@(() => ErrorMessage = null)" ShowIcon="true">
                @ErrorMessage
            </RadzenAlert>
        }

        <RadzenTemplateForm TItem="BlazorUI.Models.Auth.RegisterRequest" Data="@Model" Submit="@HandleRegisterAsync">
            <RadzenStack Gap="1rem">
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenLabel Text="First Name" Component="FirstName" />
                            <RadzenTextBox Name="FirstName" @bind-Value="Model.FirstName"
                                           Placeholder="John" Style="width: 100%;" />
                            <RadzenRequiredValidator Component="FirstName" Text="First name is required." />
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenLabel Text="Last Name" Component="LastName" />
                            <RadzenTextBox Name="LastName" @bind-Value="Model.LastName"
                                           Placeholder="Doe" Style="width: 100%;" />
                            <RadzenRequiredValidator Component="LastName" Text="Last name is required." />
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Email" Component="RegEmail" />
                    <RadzenTextBox Name="RegEmail" @bind-Value="Model.Email"
                                   Placeholder="you@example.com" Style="width: 100%;" />
                    <RadzenRequiredValidator Component="RegEmail" Text="Email is required." />
                    <RadzenEmailValidator Component="RegEmail" Text="Please enter a valid email." />
                </RadzenStack>

                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Password" Component="RegPassword" />
                    <RadzenPassword Name="RegPassword" @bind-Value="Model.Password"
                                    Placeholder="Min. 8 characters" Style="width: 100%;" />
                    <RadzenRequiredValidator Component="RegPassword" Text="Password is required." />
                    <RadzenLengthValidator Component="RegPassword" Min="8"
                                           Text="Password must be at least 8 characters." />
                </RadzenStack>

                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Confirm Password" Component="ConfirmPassword" />
                    <RadzenPassword Name="ConfirmPassword" @bind-Value="Model.ConfirmPassword"
                                    Placeholder="Re-enter password" Style="width: 100%;" />
                    <RadzenRequiredValidator Component="ConfirmPassword" Text="Please confirm your password." />
                    <RadzenCompareValidator Component="ConfirmPassword" Value="@Model.Password"
                                            Text="Passwords do not match." Operator="CompareOperator.Equal" />
                </RadzenStack>

                <RadzenButton ButtonType="ButtonType.Submit" Text="Create Account" Icon="person_add"
                              Style="width: 100%;" IsBusy="@IsLoading" BusyText="Creating account…"
                              ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" />
            </RadzenStack>
        </RadzenTemplateForm>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                Already have an account?
            </RadzenText>
            <RadzenLink Path="/login" Text="Sign in" Style="font-weight: 500;" />
        </RadzenStack>

    </RadzenStack>
</RadzenCard>
