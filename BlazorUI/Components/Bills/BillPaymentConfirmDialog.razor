<RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem" class="rz-p-4">

    @* Header *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
        <RadzenIcon Icon="receipt_long" Style="font-size: 2rem; color: var(--rz-success);" />
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.125rem">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-0"><strong>Task Completed!</strong></RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0 rz-color-secondary">A bill has been auto-created for this task.</RadzenText>
        </RadzenStack>
    </RadzenStack>

    @* Bill summary *@
    @if (!string.IsNullOrEmpty(BillTitle))
    {
        <RadzenCard Variant="Variant.Flat" class="rz-p-3" Style="border-radius: var(--rz-border-radius);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Vertical" Gap="0.125rem">
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-0"><strong>@BillTitle</strong></RadzenText>
                    @if (BillCategory.HasValue)
                    {
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">@BillCategory</RadzenText>
                    }
                </RadzenStack>
                @if (BillAmount.HasValue)
                {
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-0" Style="font-variant-numeric: tabular-nums;">
                        <strong>@($"{BillCurrency}{BillAmount:N2}")</strong>
                    </RadzenText>
                }
            </RadzenStack>
        </RadzenCard>
    }

    @* Payment question *@
    <RadzenStack Orientation="Orientation.Vertical" Gap="0.75rem">
        <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0">Has this bill been paid?</RadzenText>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem">
            <RadzenButton Text="Yes, mark as paid" Icon="check_circle" ButtonStyle="ButtonStyle.Success"
                          Variant="@(MarkAsPaid ? Variant.Filled : Variant.Outlined)"
                          Click="@(() => SetMarkAsPaid(true))" Style="flex: 1;" />
            <RadzenButton Text="No, leave unpaid" Icon="schedule" ButtonStyle="ButtonStyle.Light"
                          Variant="@(!MarkAsPaid ? Variant.Filled : Variant.Outlined)"
                          Click="@(() => SetMarkAsPaid(false))" Style="flex: 1;" />
        </RadzenStack>
    </RadzenStack>

    @* Paid-by selection — shown only when marking as paid *@
    @if (MarkAsPaid)
    {
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.375rem">
            <RadzenLabel Text="Who paid?" />
            @if (EligibleUsers.Count > 0)
            {
                <RadzenDropDown TValue="string"
                                Data="@EligibleUsers"
                                @bind-Value="@SelectedPaidByUserId"
                                TextProperty="DisplayName"
                                ValueProperty="UserId"
                                Style="width: 100%;"
                                Placeholder="Select who paid…">
                    <Template Context="user">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            @if (!string.IsNullOrEmpty((user as EligibleUserOption)?.AvatarUrl))
                            {
                                <RadzenImage Path="@((user as EligibleUserOption)!.AvatarUrl)" Style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover;" />
                            }
                            else
                            {
                                <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--rz-primary-lighter); display: flex; align-items: center; justify-content: center;">
                                    <RadzenIcon Icon="person" Style="font-size: 0.75rem; color: var(--rz-primary);" />
                                </div>
                            }
                            <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@((user as EligibleUserOption)?.DisplayName)</RadzenText>
                        </RadzenStack>
                    </Template>
                </RadzenDropDown>
            }
            else
            {
                <FriendPicker @bind-SelectedUserId="@SelectedPaidByUserId" Placeholder="Select who paid…" CurrentUser="@CurrentUserDto" />
            }
        </RadzenStack>
    }

    @* Action buttons *@
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" class="rz-pt-2" Style="border-top: 1px solid var(--rz-base-200);">
        <RadzenButton Text="Done" Icon="check" ButtonStyle="ButtonStyle.Primary" Click="Confirm" />
    </RadzenStack>
</RadzenStack>
