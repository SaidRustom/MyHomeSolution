<RadzenTemplateForm TItem="BillFormModel" Data="@Model" Submit="OnSubmit">
    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem" class="rz-p-4">

        @if (ErrorMessage is not null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="true" Close="@(() => ErrorMessage = null)">
                @ErrorMessage
            </RadzenAlert>
        }

        @* Title *@
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenLabel Text="Title" Component="Title" />
            <RadzenTextBox Name="Title" @bind-Value="@Model.Title" Placeholder="e.g. Grocery shopping" Style="width: 100%;" />
            <RadzenRequiredValidator Component="Title" Text="Title is required" />
        </RadzenStack>

        @* Amount & Currency row *@
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" Wrap="FlexWrap.Wrap">
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="flex: 1; min-width: 200px;">
                <RadzenLabel Text="Amount" Component="Amount" />
                <RadzenNumeric TValue="decimal" Name="Amount" @bind-Value="@Model.Amount" Placeholder="0.00" Style="width: 100%;" Min="0.01m" />
                <RadzenNumericRangeValidator Component="Amount" Min="0.01" Text="Amount must be greater than 0" />
            </RadzenStack>
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="width: 120px;">
                <RadzenLabel Text="Currency" Component="Currency" />
                <RadzenTextBox Name="Currency" @bind-Value="@Model.Currency" Style="width: 100%;" />
            </RadzenStack>
        </RadzenStack>

        @* Category & Date row *@
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" Wrap="FlexWrap.Wrap">
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="flex: 1; min-width: 200px;">
                <RadzenLabel Text="Category" Component="Category" />
                <RadzenDropDown TValue="BillCategory" Name="Category" @bind-Value="@Model.Category" Data="@Categories" Style="width: 100%;" />
            </RadzenStack>
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="flex: 1; min-width: 200px;">
                <RadzenLabel Text="Bill Date" Component="BillDate" />
                <RadzenDatePicker TValue="DateTimeOffset" Name="BillDate" @bind-Value="@Model.BillDate" DateFormat="MMM dd, yyyy" Style="width: 100%;" />
            </RadzenStack>
        </RadzenStack>

        @* Description *@
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenLabel Text="Description" Component="Description" />
            <RadzenTextArea Name="Description" @bind-Value="@Model.Description" Placeholder="Optional description…" Rows="2" Style="width: 100%;" />
        </RadzenStack>

        @* Notes *@
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenLabel Text="Notes" Component="Notes" />
            <RadzenTextArea Name="Notes" @bind-Value="@Model.Notes" Placeholder="Optional notes…" Rows="2" Style="width: 100%;" />
        </RadzenStack>

        @* Budget(s) *@
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenLabel Text="Budget (Optional)" />
            <RadzenDropDown TValue="Guid?"
                            Data="@AvailableBudgets.Items"
                            @bind-Value="@Model.BudgetId"
                            TextProperty="Name"
                            ValueProperty="Id"
                            AllowClear="true"
                            AllowFiltering="true"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Placeholder="Select budgets…"
                            Style="width: 100%;">
                <Template Context="budget">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenBadge Text="@((budget as BlazorUI.Models.Budgets.BudgetBriefDto)?.Category.ToString())"
                                     BadgeStyle="BadgeStyle.Info" IsPill="true" Variant="Variant.Flat" Style="font-size: 0.6rem;" />
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@((budget as BlazorUI.Models.Budgets.BudgetBriefDto)?.Name)</RadzenText>
                    </RadzenStack>
                </Template>
            </RadzenDropDown>
            <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">
                Bills will be linked to selected budgets and spending tracked.
            </RadzenText>
        </RadzenStack>

        @* Paid By — filtered to split participants + current user *@
        @if (IsEdit || Model.Splits.Count > 0)
        {
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                <RadzenLabel Text="Paid By" />
                @if (PaidByEligibleUsers.Count > 0)
                {
                    <RadzenDropDown TValue="string"
                                    Data="@PaidByEligibleUsers"
                                    @bind-Value="@Model.PaidByUserId"
                                    TextProperty="DisplayName"
                                    ValueProperty="UserId"
                                    AllowClear="true"
                                    Placeholder="Select who paid…"
                                    Style="width: 100%;">
                        <Template Context="user">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--rz-primary-lighter); display: flex; align-items: center; justify-content: center;">
                                    <RadzenIcon Icon="person" Style="font-size: 0.75rem; color: var(--rz-primary);" />
                                </div>
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@((user as EligibleUserOption)?.DisplayName)</RadzenText>
                            </RadzenStack>
                        </Template>
                    </RadzenDropDown>
                }
                else
                {
                    <FriendPicker @bind-SelectedUserId="@Model.PaidByUserId" Placeholder="Select who paid…" />
                }
                <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">Only users who are part of this bill's splits can be selected.</RadzenText>
            </RadzenStack>
        }

        @* Splits section *@
        <RadzenFieldset Text="Bill Splits" AllowCollapse="true">
            <BillSplitEditor Splits="@Model.Splits" BillAmount="@Model.Amount" CurrentUserId="@CurrentUserId" />
        </RadzenFieldset>

        @* Remaining Percentage indicator *@
        @if (Model.Splits.Count > 0)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="pie_chart" Style="font-size: 1rem;" />
                <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0">
                    Remaining: <strong>@($"{RemainingPercentage:N2}%")</strong>
                </RadzenText>
                @if (RemainingPercentage < 0)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Danger" IsPill="true" Text="Over-allocated!" Variant="Variant.Flat" />
                }
                else if (RemainingPercentage == 0)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Success" IsPill="true" Text="Fully allocated" Variant="Variant.Flat" />
                }
            </RadzenStack>
        }

        @* Footer buttons *@
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" class="rz-pt-4" Style="border-top: 1px solid var(--rz-base-200);">
            <RadzenButton Text="Cancel" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Light" Click="Cancel" ButtonType="ButtonType.Button" Disabled="@IsBusy" />
            <RadzenButton Text="@SubmitText" Icon="save" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" IsBusy="@IsBusy" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>
