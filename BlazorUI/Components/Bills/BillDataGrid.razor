<RadzenDataGrid Data="@Items"
                Count="@Count"
                TItem="BillBriefDto"
                IsLoading="@IsLoading"
                AllowPaging="true"
                PageSize="@PageSize"
                PagerHorizontalAlign="HorizontalAlign.Center"
                LoadData="@OnLoadData"
                RowSelect="@RowSelectAsync"
                AllowSorting="true"
                GridLines="DataGridGridLines.None"
                Density="Density.Compact"
                class="rz-datatable-striped"
                Style="cursor: pointer;">
    <Columns>
        <RadzenDataGridColumn TItem="BillBriefDto" Title="" Width="52px" Sortable="false" Filterable="false">
            <Template Context="bill">
                <CategoryIcon Category="@GetCategoryDisplay(bill.Category)" Size="32" />
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="BillBriefDto" MinWidth="fit-content;" Property="Title" Title="Title">
            <Template Context="bill">
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0"><strong>@bill.Title</strong></RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">@GetCategoryDisplay(bill.Category)</RadzenText>
                </RadzenStack>
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="BillBriefDto" Property="Amount" Title="Amount" Width="130px" TextAlign="TextAlign.Center">
            <Template Context="bill">
                <CurrencyDisplay Amount="@bill.Amount" Currency="@bill.Currency" />
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="BillBriefDto" Property="BillDate" Title="Date" Width="140px" SortOrder="SortOrder.Ascending">
            <Template Context="bill">
                <DateDisplay Date="@bill.BillDate" />
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="BillBriefDto" Property="IsFullyPaid" Title="Status" Width="110px" TextAlign="TextAlign.Center">
            <Template Context="bill">
                @if (bill.IsFullyPaid)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Success" IsPill="true" Variant="Variant.Flat" Text="Paid" />
                }
                else
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" IsPill="true" Variant="Variant.Flat" Text="Unpaid" />
                }
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="BillBriefDto" Title="Splits" Width="110px" TextAlign="TextAlign.Center" Sortable="false">
            <Template Context="bill">
                <RadzenBadge BadgeStyle="BadgeStyle.Info" IsPill="true" Variant="Variant.Flat" Text="@GetSplitStatusSummary(bill)" />
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="BillBriefDto" Title="Receipt" Width="80px" TextAlign="TextAlign.Center" Sortable="false">
            <Template Context="bill">
                @if (bill.HasReceipt)
                {
                    <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); font-size: 1.125rem;" />
                }
                else
                {
                    <RadzenIcon Icon="remove" Style="color: var(--rz-text-disabled-color); font-size: 1.125rem;" />
                }
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="BillBriefDto" Title="" Width="100px" Sortable="false" Filterable="false" TextAlign="TextAlign.End">
            <Template Context="bill">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0" JustifyContent="JustifyContent.End">
                    @if (OnEdit.HasDelegate)
                    {
                        <RadzenButton Icon="edit" Variant="Variant.Text" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                                      Click="@(async () => await OnEdit.InvokeAsync(bill))" title="Edit"
                                      @onclick:stopPropagation="true" />
                    }
                    @if (OnDelete.HasDelegate)
                    {
                        <RadzenButton Icon="delete_outline" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                      Click="@(async () => await OnDelete.InvokeAsync(bill))" title="Delete"
                                      @onclick:stopPropagation="true" />
                    }
                </RadzenStack>
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>
