<RadzenCard Variant="Variant.Outlined" class="rz-p-0" Style="overflow: hidden;">
    <RadzenStack Orientation="Orientation.Vertical" Gap="0">
        @* Card header *@
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-p-3" Style="border-bottom: 1px solid var(--rz-base-200);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.625rem">
                <CategoryIcon Category="@CategoryName" Size="40" />
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-0">@Bill.Title</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">@CategoryName</RadzenText>
                </RadzenStack>
            </RadzenStack>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                @if (Bill.IsFullyPaid)
                {
                    <RadzenIcon Icon="check_circle" Style="font-size: 1.25rem; color: var(--rz-success);" title="Fully paid" />
                }
                @if (Bill.HasReceipt)
                {
                    <RadzenIcon Icon="receipt_long" Style="font-size: 1rem; color: var(--rz-success);" title="Has receipt" />
                }
            </RadzenStack>
        </RadzenStack>

        @* Card body *@
        <div class="rz-p-3" style="cursor: pointer;" @onclick="ViewBillAsync">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-3">
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Amount</RadzenText>
                    <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0" Style="font-variant-numeric: tabular-nums;">
                        <strong><CurrencyDisplay Amount="@Bill.Amount" Currency="@Bill.Currency" /></strong>
                    </RadzenText>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.End" Gap="0">
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Date</RadzenText>
                    <DateDisplay Date="@Bill.BillDate" />
                </RadzenStack>
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.375rem">
                    @if (Bill.IsFullyPaid)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success" IsPill="true" Variant="Variant.Flat" Text="Paid" />
                    }
                    else
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Warning" IsPill="true" Variant="Variant.Flat" Text="Unpaid" />
                    }
                    <RadzenBadge BadgeStyle="BadgeStyle.Info" IsPill="true" Text="@($"{Bill.SplitCount} split(s)")" Variant="Variant.Flat" />
                </RadzenStack>
                <DateDisplay Date="@Bill.CreatedAt" ShowRelative="true" />
            </RadzenStack>

            @if (!string.IsNullOrEmpty(Bill.PaidByUserFullName))
            {
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem" class="rz-mt-2">
                    <RadzenIcon Icon="person" Style="font-size: 0.875rem; color: var(--rz-text-secondary-color);" />
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Paid by @Bill.PaidByUserFullName</RadzenText>
                </RadzenStack>
            }
        </div>

        @* Card footer actions *@
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.25rem" class="rz-p-2" Style="border-top: 1px solid var(--rz-base-200);">
            <RadzenButton Text="View" Icon="visibility" Variant="Variant.Text" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="ViewBillAsync" />
            @if (OnEdit.HasDelegate)
            {
                <RadzenButton Text="Edit" Icon="edit" Variant="Variant.Text" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Click="EditBillAsync" />
            }
            @if (OnDelete.HasDelegate)
            {
                <RadzenButton Icon="delete_outline" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="DeleteBillAsync" />
            }
        </RadzenStack>
    </RadzenStack>
</RadzenCard>
