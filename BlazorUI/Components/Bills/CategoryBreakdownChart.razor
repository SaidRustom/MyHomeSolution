@if (!HasData)
{
    <EmptyState Icon="pie_chart" Title="No spending data" Description="No category data available for the selected period." />
}
else
{
    <RadzenStack Orientation="Orientation.Vertical" Gap="0.75rem">
        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-0"><strong>@Title</strong></RadzenText>

        <RadzenChart Style="width: 100%; height: 280px;">
            <RadzenDonutSeries Data="@ChartItems"
                               CategoryProperty="Category"
                               ValueProperty="Amount"
                               Title="Spending"
                               Fills="@(new[] { "#4CAF50", "#FF9800", "#2196F3", "#9C27B0", "#00BCD4", "#3F51B5", "#607D8B", "#795548", "#8BC34A", "#9E9E9E", "#FF5722" })" />
            <RadzenLegend Position="LegendPosition.Bottom" />
        </RadzenChart>

        @* Category breakdown table *@
        <RadzenDataGrid Data="@ChartItems" TItem="CategoryChartItem" Density="Density.Compact"
                        AllowPaging="false" AllowSorting="false" GridLines="DataGridGridLines.None">
            <Columns>
                <RadzenDataGridColumn TItem="CategoryChartItem" Title="Category" Width="auto">
                    <Template Context="item">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <CategoryIcon Category="@item.Category" Size="24" />
                            <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@item.Category</RadzenText>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="CategoryChartItem" Property="Count" Title="Bills" Width="70px" TextAlign="TextAlign.Center" />
                <RadzenDataGridColumn TItem="CategoryChartItem" Title="Amount" Width="120px" TextAlign="TextAlign.End">
                    <Template Context="item">
                        <strong><CurrencyDisplay Amount="@item.Amount" /></strong>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenStack>
}
