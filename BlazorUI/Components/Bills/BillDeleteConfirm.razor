<RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem" class="rz-p-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: color-mix(in srgb, var(--rz-danger) 12%, transparent); display: flex; align-items: center; justify-content: center;">
            <RadzenIcon Icon="delete_forever" Style="font-size: 1.5rem; color: var(--rz-danger);" />
        </div>
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.125rem">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-0"><strong>Delete this bill?</strong></RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary rz-mb-0">This action cannot be undone.</RadzenText>
        </RadzenStack>
    </RadzenStack>

    <RadzenCard Variant="Variant.Flat" class="rz-p-3" Style="background: var(--rz-base-100); border-radius: var(--rz-border-radius);">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@BillTitle</RadzenText>
            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-0" Style="font-variant-numeric: tabular-nums;">
                <CurrencyDisplay Amount="@Amount" Currency="@Currency" />
            </RadzenText>
        </RadzenStack>
    </RadzenCard>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Cancel" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Light" Click="Cancel" />
        <RadzenButton Text="Delete Bill" Icon="delete" ButtonStyle="ButtonStyle.Danger" Click="Confirm" />
    </RadzenStack>
</RadzenStack>
