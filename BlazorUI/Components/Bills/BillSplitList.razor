@if (Splits.Count == 0)
{
    <div class="split-empty">
        <RadzenIcon Icon="group_off" Style="font-size: 2rem; display: block; margin-bottom: 0.375rem;" />
        No splits for this bill.
    </div>
}
else
{
    <div class="split-list">
        @foreach (var split in Splits)
        {
            <div class="@GetCardClass(split)">
                @* User info *@
                <div class="split-user">
                    <UserAvatar UserId="@split.UserId" AvatarUrl="@split.UserAvatarUrl" FallbackName="@split.UserFullName" Size="36px" />
                    <div class="split-user-info">
                        <div class="split-user-name">@(split.UserFullName ?? split.UserId)</div>
                        <div class="split-user-pct">@($"{split.Percentage:N1}%") of total</div>
                    </div>
                </div>

                @* Owed-to pill *@
                @if (!string.IsNullOrEmpty(split.OwedToUserId))
                {
                    <span class="split-owed-pill">
                        <RadzenIcon Icon="arrow_forward" Style="font-size: 0.6875rem;" />
                        Owes <strong>@(split.OwedToUserFullName ?? "payer")</strong>
                    </span>
                }

                @* Amount *@
                <div class="split-amount">
                    <div class="split-amount-value">
                        <CurrencyDisplay Amount="@split.Amount" Currency="@Currency" />
                    </div>
                    @if (split.PaidAt.HasValue)
                    {
                        <div class="split-amount-date">
                            <DateDisplay Date="@split.PaidAt" ShowRelative="true" />
                        </div>
                    }
                </div>

                @* Status & Action *@
                <div class="split-status-actions">
                    <StatusBadge Text="@GetStatusText(split.Status)"
                                 Severity="@GetStatusSeverity(split.Status)"
                                 Icon="@GetStatusIcon(split.Status)" />

                    @if (CanMarkAsPaid(split))
                    {
                        <RadzenButton Text="Mark Paid"
                                      Icon="payments"
                                      ButtonStyle="ButtonStyle.Success"
                                      Variant="Variant.Outlined"
                                      Size="ButtonSize.ExtraSmall"
                                      IsBusy="@(IsProcessing && _processingSplitId == split.Id)"
                                      Click="@(() => MarkAsPaidAsync(split))" />
                    }
                </div>
            </div>
        }
    </div>
}
