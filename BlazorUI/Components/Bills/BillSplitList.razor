@if (Splits.Count == 0)
{
    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary rz-mb-0 rz-text-align-center rz-p-4">No splits for this bill.</RadzenText>
}
else
{
    <RadzenDataList Data="@Splits" TItem="BillSplitDto" Style="border: none;">
        <Template Context="split">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween"
                         Wrap="FlexWrap.Wrap" Gap="0.75rem" class="rz-py-2" Style="border-bottom: 1px solid var(--rz-base-200);">
                @* User & percentage *@
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Style="flex: 1; min-width: 200px;">
                    @if (!string.IsNullOrEmpty(split.UserAvatarUrl))
                    {
                        <RadzenImage Path="@split.UserAvatarUrl" Style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; flex-shrink: 0;" />
                    }
                    else
                    {
                        <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--rz-primary-lighter); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <RadzenIcon Icon="person" Style="font-size: 1.125rem; color: var(--rz-primary);" />
                        </div>
                    }
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0"><strong>@(split.UserFullName ?? split.UserId)</strong></RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">@($"{split.Percentage:N1}%")</RadzenText>
                    </RadzenStack>
                </RadzenStack>

                @* Amount *@
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.End" Gap="0" Style="min-width: 100px;">
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0" Style="font-variant-numeric: tabular-nums;">
                        <strong><CurrencyDisplay Amount="@split.Amount" /></strong>
                    </RadzenText>
                    @if (split.PaidAt.HasValue)
                    {
                        <DateDisplay Date="@split.PaidAt" ShowRelative="true" />
                    }
                </RadzenStack>

                @* Status & action *@
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <StatusBadge Text="@GetStatusText(split.Status)"
                                 Severity="@GetStatusSeverity(split.Status)"
                                 Icon="@GetStatusIcon(split.Status)" />

                    @if (CanMarkAsPaid(split))
                    {
                        <RadzenButton Text="Mark Paid"
                                      Icon="payments"
                                      ButtonStyle="ButtonStyle.Success"
                                      Variant="Variant.Outlined"
                                      Size="ButtonSize.ExtraSmall"
                                      IsBusy="@(IsProcessing && _processingSplitId == split.Id)"
                                      Click="@(() => MarkAsPaidAsync(split))" />
                    }
                </RadzenStack>
            </RadzenStack>
        </Template>
    </RadzenDataList>
}
