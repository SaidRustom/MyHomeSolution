<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">

    @* ═══ Hero Header ═══ *@
    <div class="bill-hero">
        <CategoryIcon Category="@CategoryName" Size="56" />
        <div class="bill-hero-info">
            <h2 class="bill-hero-title">@Bill.Title</h2>
            <div class="bill-hero-badges">
                <RadzenBadge BadgeStyle="BadgeStyle.Info" IsPill="true" Text="@CategoryName" Variant="Variant.Flat" />
                @if (HasReceipt)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Success" IsPill="true" Variant="Variant.Flat">
                        <RadzenIcon Icon="receipt_long" Style="font-size: 0.8rem;" /> Receipt
                    </RadzenBadge>
                }
                @if (IsFullyPaid)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Success" IsPill="true" Variant="Variant.Flat">
                        <RadzenIcon Icon="check_circle" Style="font-size: 0.8rem;" /> Fully Paid
                    </RadzenBadge>
                }
                else if (HasSplits)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" IsPill="true" Variant="Variant.Flat">
                        <RadzenIcon Icon="pending" Style="font-size: 0.8rem;" /> Partially Paid
                    </RadzenBadge>
                }
            </div>
        </div>
    </div>

    @* ═══ Financial Summary Cards ═══ *@
    <div class="finance-grid">
        @* Total Amount *@
        <div class="finance-card">
            <div class="finance-card-accent" style="background: var(--rz-primary);"></div>
            <div class="finance-card-label">Total Amount</div>
            <div class="finance-card-value" style="color: var(--rz-primary);">
                <CurrencyDisplay Amount="@Bill.Amount" Currency="@Bill.Currency" />
            </div>
            <div class="finance-card-sub">
                <DateDisplay Date="@Bill.BillDate" />
            </div>
        </div>

        @* Paid Amount *@
        @if (HasSplits)
        {
            <div class="finance-card">
                <div class="finance-card-accent" style="background: var(--rz-success);"></div>
                <div class="finance-card-label">Paid</div>
                <div class="finance-card-value" style="color: var(--rz-success);">
                    <CurrencyDisplay Amount="@PaidAmount" Currency="@Bill.Currency" />
                </div>
                <div class="finance-card-sub">
                    @PaidSplitCount of @Bill.Splits.Count splits settled
                </div>
            </div>

            @* Outstanding *@
            <div class="finance-card">
                <div class="finance-card-accent" style="background: @(UnpaidAmount > 0 ? "var(--rz-danger)" : "var(--rz-success)");"></div>
                <div class="finance-card-label">Outstanding</div>
                <div class="finance-card-value" style="color: @(UnpaidAmount > 0 ? "var(--rz-danger)" : "var(--rz-success)");">
                    <CurrencyDisplay Amount="@UnpaidAmount" Currency="@Bill.Currency" />
                </div>
                <div class="finance-card-sub">
                    @UnpaidSplitCount remaining
                </div>
            </div>
        }
        else
        {
            @* Bill Date card when no splits *@
            <div class="finance-card">
                <div class="finance-card-accent" style="background: var(--rz-info);"></div>
                <div class="finance-card-label">Bill Date</div>
                <div class="finance-card-value" style="font-size: 1.125rem;">
                    <DateDisplay Date="@Bill.BillDate" />
                </div>
            </div>

            @* Paid By card when no splits *@
            <div class="finance-card">
                <div class="finance-card-accent" style="background: var(--rz-secondary);"></div>
                <div class="finance-card-label">Paid By</div>
                <div class="paid-by-card" style="padding: 0; background: transparent;">
                    <UserAvatar UserId="@Bill.PaidByUserId" AvatarUrl="@Bill.PaidByUserAvatarUrl" FallbackName="@Bill.PaidByUserFullName" Size="28px" />
                    <span style="font-weight: 600; font-size: 0.9375rem;">@(Bill.PaidByUserFullName ?? Bill.PaidByUserId)</span>
                </div>
            </div>
        }
    </div>

    @* ═══ Related Entity ═══ *@
    @if (HasRelatedEntity)
    {
        @if (!string.IsNullOrEmpty(Bill.RelatedEntityName) && RelatedEntityLink is not null)
        {
            <a href="@RelatedEntityLink" class="related-link" style="text-decoration: none;">
                <div class="related-link-icon">
                    <RadzenIcon Icon="@RelatedEntityIcon" Style="font-size: 1.125rem;" />
                </div>
                <RadzenStack Orientation="Orientation.Vertical" Gap="0" Style="flex: 1;">
                    <span style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--rz-text-secondary-color); font-weight: 600;">@RelatedEntityLabel</span>
                    <span style="font-weight: 600; font-size: 0.9375rem; color: var(--rz-info);">@Bill.RelatedEntityName</span>
                </RadzenStack>
                <RadzenIcon Icon="open_in_new" Style="font-size: 1rem; color: var(--rz-text-secondary-color);" />
            </a>
        }
        else
        {
            <div class="related-link">
                <div class="related-link-icon">
                    <RadzenIcon Icon="link" Style="font-size: 1.125rem;" />
                </div>
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <span style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--rz-text-secondary-color); font-weight: 600;">Linked Entity</span>
                    <span style="font-weight: 600; font-size: 0.875rem;">@(Bill.RelatedEntityName ?? $"{Bill.RelatedEntityType} — {Bill.RelatedEntityId}")</span>
                </RadzenStack>
            </div>
        }
    }

    @* ═══ Paid By (when splits present) ═══ *@
    @if (HasSplits)
    {
        <div class="paid-by-card" style="border: 1px solid var(--rz-base-200); border-radius: var(--rz-border-radius);">
            <UserAvatar UserId="@Bill.PaidByUserId" AvatarUrl="@Bill.PaidByUserAvatarUrl" FallbackName="@Bill.PaidByUserFullName" Size="36px" />
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <span style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--rz-text-secondary-color); font-weight: 600;">Paid By</span>
                <span style="font-weight: 600; font-size: 0.9375rem;">@(Bill.PaidByUserFullName ?? Bill.PaidByUserId)</span>
            </RadzenStack>
        </div>
    }

    @* ═══ Outstanding Debts Banner ═══ *@
    @if (OutstandingDebts.Count > 0)
    {
        <div class="debt-banner">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="margin-bottom: 0.5rem;">
                <RadzenIcon Icon="swap_horiz" Style="font-size: 1.125rem; color: var(--rz-warning-dark);" />
                <span style="font-weight: 700; color: var(--rz-warning-dark); font-size: 0.875rem;">Outstanding Debts</span>
            </RadzenStack>
            @foreach (var debt in OutstandingDebts)
            {
                <div class="debt-row">
                    <div class="debt-arrow">
                        <RadzenIcon Icon="arrow_forward" Style="font-size: 0.75rem;" />
                    </div>
                    <span><strong>@debt.DebtorName</strong> owes <strong>@debt.CreditorName</strong></span>
                    <span class="debt-amount">
                        <CurrencyDisplay Amount="@debt.Amount" Currency="@Bill.Currency" />
                    </span>
                </div>
            }
        </div>
    }

    @* ═══ Splits Section ═══ *@
    @if (HasSplits)
    {
        <div class="detail-section">
            <div class="detail-section-header">
                <RadzenIcon Icon="call_split" Style="font-size: 1.25rem; color: var(--rz-primary);" />
                <span class="detail-section-title">Splits</span>
                <span class="detail-section-count">@Bill.Splits.Count</span>
            </div>
            <BillSplitList Splits="@Bill.Splits"
                           AllowMarkAsPaid="true"
                           OnMarkAsPaid="MarkSplitAsPaidAsync"
                           IsProcessing="@IsProcessing"
                           Currency="@Bill.Currency" />
        </div>
    }

    @* ═══ Line Items Section ═══ *@
    @if (HasItems)
    {
        <div class="detail-section">
            <div class="detail-section-header">
                <RadzenIcon Icon="list_alt" Style="font-size: 1.25rem; color: var(--rz-primary);" />
                <span class="detail-section-title">Line Items</span>
                <span class="detail-section-count">@Bill.Items.Count</span>
            </div>
            <BillItemList Items="@Bill.Items" />
        </div>
    }

    @* ═══ Description ═══ *@
    @if (HasDescription)
    {
        <div class="detail-section">
            <div class="detail-section-header">
                <RadzenIcon Icon="description" Style="font-size: 1.25rem; color: var(--rz-text-secondary-color);" />
                <span class="detail-section-title">Description</span>
            </div>
            <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@Bill.Description</RadzenText>
        </div>
    }

    @* ═══ Notes ═══ *@
    @if (HasNotes)
    {
        <div class="detail-section">
            <div class="detail-section-header">
                <RadzenIcon Icon="sticky_note_2" Style="font-size: 1.25rem; color: var(--rz-text-secondary-color);" />
                <span class="detail-section-title">Notes</span>
            </div>
            <div class="notes-content">@Bill.Notes</div>
        </div>
    }

    @* ═══ Receipt Section ═══ *@
    @if (HasReceipt)
    {
        <div class="receipt-card">
            <div class="receipt-header">
                <div class="receipt-icon-wrap">
                    <RadzenIcon Icon="receipt_long" Style="font-size: 1.25rem;" />
                </div>
                <RadzenStack Orientation="Orientation.Vertical" Gap="0" Style="flex: 1;">
                    <span style="font-weight: 600; font-size: 0.9375rem;">Receipt Attached</span>
                    <span style="font-size: 0.8125rem; color: var(--rz-text-secondary-color);">A receipt image is available for this bill.</span>
                </RadzenStack>
                <RadzenButton Text="@(ShowReceiptPreview ? "Hide" : "View")"
                              Icon="@(ShowReceiptPreview ? "visibility_off" : "visibility")"
                              Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                              IsBusy="@IsLoadingReceipt" BusyText="Loading…"
                              Click="ViewReceiptAsync" />
            </div>
            @if (ShowReceiptPreview && ReceiptDataUrl is not null)
            {
                <div class="receipt-preview">
                    <img src="@ReceiptDataUrl" alt="Receipt for @Bill.Title" />
                </div>
            }
        </div>
    }

    @* ═══ Audit Footer ═══ *@
    <div class="audit-footer">
        <span class="audit-item">
            <RadzenIcon Icon="schedule" Style="font-size: 0.875rem;" />
            Created <DateDisplay Date="@Bill.CreatedAt" ShowRelative="true" />
            by @Bill.CreatedBy
        </span>
        @if (Bill.LastModifiedAt.HasValue)
        {
            <span class="audit-item">
                <RadzenIcon Icon="update" Style="font-size: 0.875rem;" />
                Modified <DateDisplay Date="@Bill.LastModifiedAt" ShowRelative="true" />
            </span>
        }
    </div>
</RadzenStack>
