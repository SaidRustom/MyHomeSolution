<RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" class="rz-mb-4">
    @if (Breadcrumb is not null)
    {
        <div class="rz-mb-1">
            @Breadcrumb
        </div>
    }
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
            @if (!string.IsNullOrEmpty(Icon))
            {
                <RadzenIcon Icon="@Icon" Style="font-size: 1.75rem; color: var(--rz-primary);" />
            }
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0"><strong>@Title</strong></RadzenText>
                @if (!string.IsNullOrEmpty(Subtitle))
                {
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">@Subtitle</RadzenText>
                }
            </RadzenStack>
        </RadzenStack>
        @if (Actions is not null)
        {
            <div>
                @Actions
            </div>
        }
    </RadzenStack>
</RadzenStack>
