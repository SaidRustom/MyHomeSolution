<RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem" class="rz-p-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
        <RadzenIcon Icon="help_outline" Style="font-size: 2rem; color: var(--rz-warning);" />
        <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0">@Message</RadzenText>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="@CancelText"
                      Variant="Variant.Flat"
                      ButtonStyle="ButtonStyle.Light"
                      Click="Cancel"
                      Disabled="@IsBusy" />
        <RadzenButton Text="@ConfirmText"
                      Icon="@ConfirmIcon"
                      ButtonStyle="@ConfirmStyle"
                      Click="Confirm"
                      IsBusy="@IsBusy" />
    </RadzenStack>
</RadzenStack>
