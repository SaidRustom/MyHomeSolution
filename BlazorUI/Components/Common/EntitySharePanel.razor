@using BlazorUI.Models.Enums

<RadzenCard Variant="Variant.Outlined">
    <RadzenStack Orientation="Orientation.Vertical" Gap="0.75rem" class="rz-p-3">

        @* Header *@
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="0.5rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="group" Style="color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-0"><strong>Sharing</strong></RadzenText>
                @if (_shares is not null)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Info" IsPill="true" Variant="Variant.Flat"
                                 Text="@($"{_shares.Count + 1}")" title="Total people with access" />
                }
            </RadzenStack>
            @if (CanManage)
            {
                <RadzenButton Text="Share" Icon="person_add" ButtonStyle="ButtonStyle.Primary"
                              Variant="Variant.Outlined" Size="ButtonSize.Small"
                              Click="OpenShareDialogAsync" />
            }
        </RadzenStack>

        @* Stacked avatar row (preview of all users) *@
        @if (_shares is { Count: > 0 })
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" Wrap="FlexWrap.Wrap"
                         Style="padding: 0.25rem 0;">
                <div style="position: relative; z-index: 1;">
                    <UserAvatar UserId="@OwnerId" AvatarUrl="@OwnerAvatarUrl" FallbackName="@OwnerName"
                                Size="32px" FallbackIcon="shield_person" Background="var(--rz-warning-lighter)" IconColor="var(--rz-warning)" />
                </div>
                @{ var idx = 0; }
                @foreach (var share in _shares.Take(6))
                {
                    idx++;
                    <div style="position: relative; margin-left: -8px; z-index: @(10 - idx);">
                        <UserAvatar UserId="@share.SharedWithUserId" AvatarUrl="@share.AvatarUrl"
                                    FallbackName="@share.DisplayName" Size="32px" />
                    </div>
                }
                @if (_shares.Count > 6)
                {
                    <div style="margin-left: -8px; width: 32px; height: 32px; border-radius: 50%; background: var(--rz-base-300); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 600; color: var(--rz-text-secondary-color);">
                        +@(_shares.Count - 6)
                    </div>
                }
            </RadzenStack>
        }

        @* Owner row *@
        <div style="padding: 0.625rem 0.75rem; background: var(--rz-base-background); border-radius: var(--rz-border-radius); border: 1px solid var(--rz-base-200);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="0.5rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.625rem">
                    <UserAvatar UserId="@OwnerId" AvatarUrl="@OwnerAvatarUrl" FallbackName="@OwnerName"
                                Size="36px" FallbackIcon="shield_person" Background="var(--rz-warning-lighter)" IconColor="var(--rz-warning)" />
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0" Style="font-weight: 600;">
                            @(OwnerName ?? OwnerId ?? "Unknown")
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Creator</RadzenText>
                    </RadzenStack>
                </RadzenStack>
                <RadzenBadge BadgeStyle="BadgeStyle.Warning" IsPill="true" Text="Owner" Variant="Variant.Flat" />
            </RadzenStack>
        </div>

        @* Shared users list *@
        @if (_shares is not null)
        {
            @foreach (var share in _shares)
            {
                <div style="padding: 0.5rem 0.75rem; border-radius: var(--rz-border-radius); border: 1px solid var(--rz-base-100); transition: background-color 0.15s ease;"
                     class="entity-share-row">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="0.5rem">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.625rem" Style="min-width: 0; flex: 1;">
                            <UserAvatar UserId="@share.SharedWithUserId" AvatarUrl="@share.AvatarUrl"
                                        FallbackName="@share.DisplayName" Size="36px" />
                            <RadzenStack Orientation="Orientation.Vertical" Gap="0" Style="min-width: 0;">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0" Style="font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @(share.DisplayName ?? share.SharedWithUserId)
                                </RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">
                                    Shared @share.SharedAt.LocalDateTime.ToString("MMM dd, yyyy")
                                </RadzenText>
                            </RadzenStack>
                        </RadzenStack>

                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.375rem">
                            @if (CanManage)
                            {
                                <RadzenDropDown TValue="SharePermission"
                                                Value="@share.Permission"
                                                ValueChanged="@(async val => await UpdatePermissionAsync(share, val))"
                                                Data="@PermissionOptions"
                                                Style="width: 100px;"
                                                Disabled="@(_busyShareId == share.Id)" />
                                <RadzenButton Icon="person_remove" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger"
                                              Size="ButtonSize.Small" title="Revoke access"
                                              Click="@(async () => await RevokeShareAsync(share))"
                                              IsBusy="@(_busyShareId == share.Id)" />
                            }
                            else
                            {
                                <RadzenBadge BadgeStyle="@(share.Permission == SharePermission.Edit ? BadgeStyle.Success : BadgeStyle.Info)"
                                             IsPill="true" Text="@share.Permission.ToString()" Variant="Variant.Flat" />
                            }
                        </RadzenStack>
                    </RadzenStack>
                </div>
            }
        }

        @* Loading state *@
        @if (_isLoading)
        {
            <RadzenStack AlignItems="AlignItems.Center" class="rz-p-2">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                           Size="ProgressBarCircularSize.Small" />
            </RadzenStack>
        }
        else if (_shares is { Count: 0 })
        {
            <RadzenStack AlignItems="AlignItems.Center" class="rz-py-3" Gap="0.25rem">
                <RadzenIcon Icon="group_off" Style="font-size: 1.5rem; color: var(--rz-text-disabled-color);" />
                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary rz-mb-0" Style="text-align: center;">
                    Not shared with anyone yet.
                </RadzenText>
                @if (CanManage)
                {
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0" Style="text-align: center;">
                        Tap <strong>Share</strong> to invite people.
                    </RadzenText>
                }
            </RadzenStack>
        }
    </RadzenStack>
</RadzenCard>

<style>
    .entity-share-row:hover {
        background-color: var(--rz-base-background);
    }
</style>
