<RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem" class="rz-p-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
        <RadzenIcon Icon="admin_panel_settings" Style="font-size: 2rem; color: var(--rz-primary);" />
        <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0">
            Assign a role to <strong>@UserName</strong>
        </RadzenText>
    </RadzenStack>

    <RadzenStack Gap="0.25rem">
        <RadzenLabel Text="Role" Component="RoleName" />
        <RadzenDropDown TValue="string" Name="RoleName" @bind-Value="SelectedRole"
                        Data="@AvailableRoles" Style="width: 100%;"
                        Placeholder="Select a role…" />
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Cancel" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Light"
                      Click="Cancel" />
        <RadzenButton Text="Assign" Icon="check" ButtonStyle="ButtonStyle.Primary"
                      Click="Confirm" Disabled="@string.IsNullOrWhiteSpace(SelectedRole)" />
    </RadzenStack>
</RadzenStack>
