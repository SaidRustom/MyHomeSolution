@using BlazorUI.Models.Users

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">

    @* Back button + Actions header *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="0.5rem">
        <RadzenButton Text="Back to Users" Icon="arrow_back" Variant="Variant.Text" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Click="GoBackAsync" />
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.375rem">
            @if (User.IsActive)
            {
                <RadzenButton Text="Deactivate" Icon="block" ButtonStyle="ButtonStyle.Warning" Variant="Variant.Outlined" Size="ButtonSize.Small"
                              Click="DeactivateAsync" IsBusy="@IsProcessing" />
            }
            else
            {
                <RadzenButton Text="Activate" Icon="check_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Outlined" Size="ButtonSize.Small"
                              Click="ActivateAsync" IsBusy="@IsProcessing" />
            }
        </RadzenStack>
    </RadzenStack>

    @* Main detail card *@
    <RadzenCard Variant="Variant.Outlined">
        <RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem" class="rz-p-2">

            @* User header *@
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.875rem">
                <RadzenGravatar Email="@User.Email" Style="width: 56px; height: 56px; border-radius: 50%;" />
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0"><strong>@User.FullName</strong></RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        @if (User.IsActive)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Success" IsPill="true" Text="Active" Variant="Variant.Flat" />
                        }
                        else
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Danger" IsPill="true" Text="Inactive" Variant="Variant.Flat" />
                        }
                        @if (User.EmailConfirmed)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" IsPill="true" Variant="Variant.Flat">
                                <RadzenIcon Icon="verified" Style="font-size: 0.8rem;" /> Verified
                            </RadzenBadge>
                        }
                    </RadzenStack>
                </RadzenStack>
            </RadzenStack>

            @* Key info row *@
            <RadzenRow Gap="1rem" RowGap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.125rem">
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Email</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0">@User.Email</RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="4">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.125rem">
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Created</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0">
                            <DateDisplay Date="@User.CreatedAt" />
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="4">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.125rem">
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Last Login</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0">
                            @if (User.LastLoginAt.HasValue)
                            {
                                <DateDisplay Date="@User.LastLoginAt.Value" />
                            }
                            else
                            {
                                <span style="color: var(--rz-text-disabled-color);">Never</span>
                            }
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>

            @* Roles section *@
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-0"><strong>Roles</strong></RadzenText>
                    <RadzenButton Text="Assign Role" Icon="add" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" Size="ButtonSize.Small"
                                  Click="AssignRoleAsync" />
                </RadzenStack>

                @if (User.Roles.Count > 0)
                {
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" Wrap="FlexWrap.Wrap">
                        @foreach (var role in User.Roles)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Primary" IsPill="true" Variant="Variant.Outlined" Style="padding: 0.25rem 0.75rem;">
                                @role
                                <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall"
                                              Style="margin-left: 0.25rem; padding: 0;"
                                              Click="@(async () => await OnRemoveRole.InvokeAsync(role))" />
                            </RadzenBadge>
                        }
                    </RadzenStack>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0" Style="color: var(--rz-text-disabled-color);">
                        No roles assigned
                    </RadzenText>
                }
            </RadzenStack>

        </RadzenStack>
    </RadzenCard>
</RadzenStack>
