@using BlazorUI.Models.UserConnections

<RadzenCard Variant="Variant.Outlined" class="rz-p-3">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="0.75rem" Wrap="FlexWrap.Wrap">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Style="flex: 1; min-width: 200px;">
            <RadzenGravatar Email="@Request.ConnectedUserEmail" Style="width: 40px; height: 40px; border-radius: 50%;" />
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0"><strong>@(Request.ConnectedUserName ?? "Unknown User")</strong></RadzenText>
                <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">@Request.ConnectedUserEmail</RadzenText>
            </RadzenStack>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">
                @Request.CreatedAt.ToString("MMM d, yyyy")
            </RadzenText>
            @if (IsSent)
            {
                <RadzenButton Text="Cancel" Icon="close" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.ExtraSmall"
                              Click="@(() => OnCancel.InvokeAsync(Request))" />
            }
            else
            {
                <RadzenButton Text="Accept" Icon="check" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.ExtraSmall"
                              Click="@(() => OnAccept.InvokeAsync(Request))" />
                <RadzenButton Text="Decline" Icon="close" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall"
                              Click="@(() => OnDecline.InvokeAsync(Request))" />
            }
        </RadzenStack>
    </RadzenStack>
</RadzenCard>
