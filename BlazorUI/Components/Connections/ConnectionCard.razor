@using BlazorUI.Models.UserConnections

<RadzenCard Variant="Variant.Outlined" class="rz-p-3">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="0.75rem" Wrap="FlexWrap.Wrap">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Style="flex: 1; min-width: 200px;">
            <RadzenGravatar Email="@Connection.ConnectedUserEmail" Style="width: 40px; height: 40px; border-radius: 50%;" />
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0"><strong>@(Connection.ConnectedUserName ?? "Unknown User")</strong></RadzenText>
                <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">@Connection.ConnectedUserEmail</RadzenText>
            </RadzenStack>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">
                Connected @Connection.RespondedAt?.ToString("MMM d, yyyy")
            </RadzenText>
            <RadzenButton Icon="person_remove" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                          Click="@(() => OnRemove.InvokeAsync(Connection))" title="Remove connection" />
        </RadzenStack>
    </RadzenStack>
</RadzenCard>
