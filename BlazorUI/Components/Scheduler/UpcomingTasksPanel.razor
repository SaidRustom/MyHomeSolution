<RadzenCard Variant="Variant.Outlined" class="rz-p-0" Style="height: 640px; display: flex; flex-direction: column;">
    @* Header *@
    <RadzenStack Orientation="Orientation.Vertical" Gap="0" Style="border-bottom: 1px solid var(--rz-base-200); flex-shrink: 0;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween"
                     class="rz-px-4 rz-py-3">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="@HeaderIcon" Style="color: var(--rz-primary);" />
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-0"><strong>@HeaderTitle</strong></RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">@HeaderSubtitle</RadzenText>
                </RadzenStack>
            </RadzenStack>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                @if (!IsLoading)
                {
                    <RadzenButton Icon="refresh" Variant="Variant.Text" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.ExtraSmall" Click="LoadDataAsync" title="Refresh" />
                }
                <RadzenButton Icon="add" Variant="Variant.Text" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.ExtraSmall" Click="CreateTaskClicked" title="New task for this day" />
            </RadzenStack>
        </RadzenStack>

        @* Summary stats *@
        @if (!IsLoading && _occurrences.Count > 0)
        {
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceAround"
                         class="rz-px-4 rz-pb-2" Style="border-bottom: 1px solid var(--rz-base-100);">
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0">
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-0" Style="font-weight: 700; color: var(--rz-warning);">@_pendingCount</RadzenText>
                    <RadzenText TextStyle="TextStyle.Overline" class="rz-mb-0 rz-color-secondary">Pending</RadzenText>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0">
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-0" Style="font-weight: 700; color: var(--rz-info);">@_inProgressCount</RadzenText>
                    <RadzenText TextStyle="TextStyle.Overline" class="rz-mb-0 rz-color-secondary">Active</RadzenText>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0">
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-0" Style="font-weight: 700; color: var(--rz-success);">@_completedCount</RadzenText>
                    <RadzenText TextStyle="TextStyle.Overline" class="rz-mb-0 rz-color-secondary">Done</RadzenText>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0">
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-0" Style="font-weight: 700; color: var(--rz-danger);">@_overdueCount</RadzenText>
                    <RadzenText TextStyle="TextStyle.Overline" class="rz-mb-0 rz-color-secondary">Overdue</RadzenText>
                </RadzenStack>
            </RadzenStack>
        }
    </RadzenStack>

    @* Body *@
    <div style="flex: 1; overflow-y: auto;">
        @if (IsLoading)
        {
            <RadzenStack AlignItems="AlignItems.Center" class="rz-p-4">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
            </RadzenStack>
        }
        else if (_occurrences.Count == 0)
        {
            <RadzenStack AlignItems="AlignItems.Center" class="rz-p-6" Gap="0.75rem">
                <RadzenIcon Icon="event_available" Style="font-size: 3rem; color: var(--rz-text-disabled-color);" />
                <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0" Style="font-weight: 500;">No tasks for this day</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary rz-mb-0" Style="text-align: center;">
                    Click "+" above to create a task for @SelectedDate.ToString("MMMM dd")
                </RadzenText>
            </RadzenStack>
        }
        else
        {
            @foreach (var occ in _occurrences)
            {
                <div style="padding: 0.75rem 1rem; border-bottom: 1px solid var(--rz-base-100); transition: background 0.15s;"
                     class="rz-hover-highlight">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Start" JustifyContent="JustifyContent.SpaceBetween">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="flex: 1; min-width: 0;">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.375rem">
                                    <div style="width: 10px; height: 10px; border-radius: 50%; background: @GetPriorityColor(occ.TaskPriority); flex-shrink: 0;" />
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0" Style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        @occ.TaskTitle
                                    </RadzenText>
                                </RadzenStack>
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.375rem" Style="padding-left: 1.375rem;">
                                    @if (occ.EstimatedDurationMinutes.HasValue)
                                    {
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.125rem">
                                            <RadzenIcon Icon="timer" Style="font-size: 0.7rem; color: var(--rz-text-secondary-color);" />
                                            <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">@(occ.EstimatedDurationMinutes)m</RadzenText>
                                        </RadzenStack>
                                    }
                                    <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">@occ.TaskCategory</RadzenText>
                                </RadzenStack>
                            </RadzenStack>
                            <StatusBadge Text="@occ.Status.ToString()" Severity="@GetStatusSeverity(occ.Status)" />
                        </RadzenStack>

                        @* Quick actions *@
                        @if (occ.Status is OccurrenceStatus.Pending or OccurrenceStatus.Overdue or OccurrenceStatus.InProgress)
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" Style="padding-left: 1.375rem;">
                                @if (occ.Status is OccurrenceStatus.Pending or OccurrenceStatus.Overdue)
                                {
                                    <RadzenButton Text="Start" Icon="play_arrow" Variant="Variant.Text" ButtonStyle="ButtonStyle.Info"
                                                  Size="ButtonSize.ExtraSmall" Click="@(() => StartOccurrenceAsync(occ.Id))" IsBusy="@(_busyId == occ.Id)" />
                                }
                                <RadzenButton Text="Complete" Icon="check" Variant="Variant.Text" ButtonStyle="ButtonStyle.Success"
                                              Size="ButtonSize.ExtraSmall" Click="@(() => CompleteOccurrenceAsync(occ.Id))" IsBusy="@(_busyId == occ.Id)" />
                                <RadzenButton Text="Skip" Icon="skip_next" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light"
                                              Size="ButtonSize.ExtraSmall" Click="@(() => SkipOccurrenceAsync(occ.Id))" IsBusy="@(_busyId == occ.Id)" />
                            </RadzenStack>
                        }
                    </RadzenStack>
                </div>
            }
        }
    </div>
</RadzenCard>
