<RadzenCard Variant="Variant.Outlined" class="rz-p-3">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Wrap="FlexWrap.Wrap">
        <RadzenIcon Icon="filter_list" Style="color: var(--rz-primary);" />

        <RadzenDropDown TValue="TaskCategory?"
                        Value="@Category"
                        ValueChanged="OnCategoryChanged"
                        Data="@Categories"
                        Placeholder="Category"
                        AllowClear="true"
                        Style="width: 160px;" />

        <RadzenDropDown TValue="TaskPriority?"
                        Value="@Priority"
                        ValueChanged="OnPriorityChanged"
                        Data="@Priorities"
                        Placeholder="Priority"
                        AllowClear="true"
                        Style="width: 140px;" />

        <RadzenDropDown TValue="OccurrenceStatus?"
                        Value="@Status"
                        ValueChanged="OnStatusChanged"
                        Data="@Statuses"
                        Placeholder="Status"
                        AllowClear="true"
                        Style="width: 150px;" />

        <FriendPicker SelectedUserId="@AssignedToUserId"
                      SelectedUserIdChanged="OnAssigneeChanged"
                      Placeholder="Assignee"
                      Style="width: 200px;" />

        @if (HasActiveFilters)
        {
            <RadzenButton Text="Reset" Icon="clear" Variant="Variant.Text" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Click="ResetAsync" />
        }
    </RadzenStack>
</RadzenCard>
