<RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem" class="rz-p-4">

    @if (ErrorMessage is not null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter"
                     AllowClose="true" Close="@(() => ErrorMessage = null)">
            @ErrorMessage
        </RadzenAlert>
    }

    @* Current amount display *@
    <RadzenCard Variant="Variant.Flat" class="rz-p-3" Style="background: var(--rz-base-100);">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.125rem">
                <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">Current Allocated Amount</RadzenText>
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0"><strong>$@CurrentAmount.ToString("N2")</strong></RadzenText>
            </RadzenStack>
            @if (!string.IsNullOrEmpty(BudgetName))
            {
                <RadzenBadge Text="@BudgetName" BadgeStyle="BadgeStyle.Info" IsPill="true" Variant="Variant.Flat" />
            }
        </RadzenStack>
    </RadzenCard>

    @* New amount input *@
    <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
        <RadzenLabel Text="New Amount" Component="NewAmount" />
        <RadzenNumeric TValue="decimal" Name="NewAmount" @bind-Value="@NewAmount"
                       Placeholder="0.00" Style="width: 100%;" Min="0m" />
    </RadzenStack>

    @* Difference preview *@
    @if (Difference != 0)
    {
        <RadzenCard Variant="Variant.Flat" class="rz-p-3"
                    Style="@($"border-left: 3px solid {DifferenceColor}; background: var(--rz-base-100);")">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="@(Difference > 0 ? "arrow_upward" : "arrow_downward")"
                            Style="@($"color: {DifferenceColor};")" />
                <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">
                    Difference: <strong style="color: @DifferenceColor;">@DifferenceDisplay</strong>
                </RadzenText>
            </RadzenStack>
        </RadzenCard>
    }

    @* Notes *@
    <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
        <RadzenLabel Text="Notes (Optional)" />
        <RadzenTextArea @bind-Value="@Notes" Placeholder="Reason for adjustment…" Rows="2" Style="width: 100%;" />
    </RadzenStack>

    @* Transfer toggle *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenSwitch @bind-Value="@EnableTransfer" />
        <RadzenLabel Text="Transfer difference to/from another occurrence" Style="margin: 0;" />
    </RadzenStack>

    @if (EnableTransfer)
    {
        <RadzenCard Variant="Variant.Outlined" class="rz-p-3">
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.75rem">
                @* Select budget for transfer *@
                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                    <RadzenLabel Text="Transfer Budget" />
                    <RadzenDropDown TValue="Guid?"
                                    Data="@AvailableBudgets.Items"
                                    Value="@_selectedTransferBudgetId"
                                    TextProperty="Name"
                                    ValueProperty="Id"
                                    AllowClear="true"
                                    AllowFiltering="true"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    Placeholder="Select budget…"
                                    Style="width: 100%;"
                                    Change="OnTransferBudgetChanged" />
                </RadzenStack>

                @* Select occurrence *@
                @if (TransferOccurrences.Count > 0)
                {
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                        <RadzenLabel Text="Transfer Occurrence" />
                        <RadzenDropDown TValue="Guid?"
                                        @bind-Value="@TransferOccurrenceId"
                                        Data="@TransferOccurrences"
                                        ValueProperty="Id"
                                        AllowClear="true"
                                        Placeholder="Select occurrence…"
                                        Style="width: 100%;">
                            <Template Context="occ">
                                @FormatOccurrenceLabel((BudgetOccurrenceDto)occ)
                            </Template>
                        </RadzenDropDown>
                    </RadzenStack>
                }

                @* Transfer reason *@
                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                    <RadzenLabel Text="Transfer Reason" />
                    <RadzenTextBox @bind-Value="@TransferReason" Placeholder="Reason for transfer…" Style="width: 100%;" />
                </RadzenStack>

                @* Preview *@
                @if (TransferOccurrenceId.HasValue && Difference != 0)
                {
                    var targetOcc = TransferOccurrences.FirstOrDefault(o => o.Id == TransferOccurrenceId.Value);
                    @if (targetOcc is not null)
                    {
                        <RadzenCard Variant="Variant.Flat" class="rz-p-2" Style="background: var(--rz-base-100);">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.375rem">
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">Transfer Preview</RadzenText>
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.375rem">
                                    <RadzenIcon Icon="swap_horiz" Style="color: var(--rz-info);" />
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">
                                        $@(Math.Abs(Difference).ToString("N2")) will be
                                        @(Difference > 0 ? "taken from" : "sent to")
                                        the selected occurrence
                                    </RadzenText>
                                </RadzenStack>
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0 rz-color-secondary">
                                    Target remaining after transfer: $@((targetOcc.RemainingAmount + (Difference > 0 ? -Math.Abs(Difference) : Math.Abs(Difference))).ToString("N2"))
                                </RadzenText>
                            </RadzenStack>
                        </RadzenCard>
                    }
                }
            </RadzenStack>
        </RadzenCard>
    }

    @* Footer *@
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End"
                 Gap="0.5rem" class="rz-pt-2" Style="border-top: 1px solid var(--rz-base-200);">
        <RadzenButton Text="Cancel" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Light"
                      Click="Cancel" ButtonType="ButtonType.Button" Disabled="@IsBusy" />
        <RadzenButton Text="Update Amount" Icon="save" ButtonStyle="ButtonStyle.Primary"
                      Click="OnSubmitAsync" IsBusy="@IsBusy" />
    </RadzenStack>
</RadzenStack>
