@using BlazorUI.Components.Common
@using BlazorUI.Components.Bills

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem" class="rz-p-4" Style="min-width: 500px; max-width: 700px;">

    <RadzenText TextStyle="TextStyle.H6" Style="margin: 0; font-weight: 600;">
        <RadzenIcon Icon="receipt_long" Style="vertical-align: middle; margin-right: 0.25rem;" />
        Scan Receipt
    </RadzenText>

    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary" Style="margin: 0;">
        Upload a receipt image to automatically match items with your shopping list, calculate taxes, and create a bill.
    </RadzenText>

    @if (_errorMessage is not null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" ShowIcon="true"
                     AllowClose="true" Close="@(() => _errorMessage = null)">
            @_errorMessage
        </RadzenAlert>
    }

    @if (_result is null)
    {
        @* Phase 1: Upload & Process *@
        <RadzenFieldset Text="Receipt Image">
            <ImageCapture Accept="image/jpeg,image/png,image/webp"
                          MaxFileSizeBytes="@(20 * 1024 * 1024)"
                          UploadText="Upload Receipt"
                          CameraText="Scan Receipt"
                          ShowPreview="true"
                          PreviewStyle="max-width: 100%; max-height: 250px; border-radius: 8px; object-fit: contain;"
                          OnImageCaptured="OnImageCaptured" />
        </RadzenFieldset>

        <RadzenFieldset Text="Bill Splits (optional)" AllowCollapse="true">
            <BillSplitEditor Splits="@_splits" BillAmount="0" CurrentUserId="@_currentUserId" />
        </RadzenFieldset>

        @if (_isProcessing)
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem" Style="padding: 1rem;">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
                    Analyzing receipt… Matching items across your shopping lists.
                </RadzenText>
            </RadzenStack>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End"
                     Gap="0.5rem" class="rz-pt-4"
                     Style="border-top: 1px solid var(--rz-base-200);">
            <RadzenButton Text="Cancel" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Light"
                          Click="Cancel" Disabled="@_isProcessing" />
            <RadzenButton Text="Process Receipt" Icon="receipt_long"
                          ButtonStyle="ButtonStyle.Primary" Click="ProcessAsync"
                          IsBusy="@_isProcessing" BusyText="Processing…"
                          Disabled="@(_capturedImage is null)" />
        </RadzenStack>
    }
    else
    {
        @* Phase 2: Results & Cross-List Resolution *@
        <RadzenTabs>
            <Tabs>
                @* Summary tab *@
                <RadzenTabsItem Text="Summary" Icon="summarize">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem" class="rz-pt-2">
                        <RadzenRow Gap="0.5rem">
                            <RadzenColumn Size="6">
                                <StatCard Title="Items Checked" Value="@_result.CheckedItems.Count.ToString()"
                                          Icon="check_circle" IconColor="var(--rz-success)" />
                            </RadzenColumn>
                            <RadzenColumn Size="6">
                                <StatCard Title="Items Added" Value="@_result.AddedItems.Count.ToString()"
                                          Icon="add_circle" IconColor="var(--rz-info)" />
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenCard Variant="Variant.Outlined" class="rz-p-3">
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-0"><strong>@_result.Bill.Title</strong></RadzenText>
                                <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-0">
                                    <strong><CurrencyDisplay Amount="@_result.Bill.Amount" /></strong>
                                </RadzenText>
                            </RadzenStack>
                            @if (!string.IsNullOrEmpty(_result.Bill.Description))
                            {
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">@_result.Bill.Description</RadzenText>
                            }
                        </RadzenCard>

                        @if (_result.CheckedItems.Count > 0)
                        {
                            <RadzenFieldset Text="@($"Checked Off ({_result.CheckedItems.Count})")">
                                @foreach (var item in _result.CheckedItems)
                                {
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-py-1">
                                        <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); font-size: 1rem;" />
                                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@item.Name</RadzenText>
                                    </RadzenStack>
                                }
                            </RadzenFieldset>
                        }

                        @if (_result.AddedItems.Count > 0)
                        {
                            <RadzenFieldset Text="@($"Added to List ({_result.AddedItems.Count})")">
                                @foreach (var item in _result.AddedItems)
                                {
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-py-1">
                                        <RadzenIcon Icon="add_circle" Style="color: var(--rz-info); font-size: 1rem;" />
                                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@item.Name</RadzenText>
                                    </RadzenStack>
                                }
                            </RadzenFieldset>
                        }
                    </RadzenStack>
                </RadzenTabsItem>

                @* Bill Items tab *@
                <RadzenTabsItem Text="Bill Items" Icon="receipt">
                    <div class="rz-pt-2">
                        <BillItemList Items="@_result.Bill.Items" />
                    </div>
                </RadzenTabsItem>

                @* Cross-List Matches tab - only if there are matches *@
                @if (_result.CrossListMatches.Count > 0)
                {
                    <RadzenTabsItem Text="@($"Cross-List ({_result.CrossListMatches.Count})")" Icon="swap_horiz">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem" class="rz-pt-2">
                            <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true" AllowClose="false" Size="AlertSize.Small">
                                These items were found on other shopping lists. Choose where to assign each item.
                            </RadzenAlert>

                            @foreach (var match in _result.CrossListMatches)
                            {
                                <RadzenCard Variant="Variant.Outlined" class="rz-p-3">
                                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
                                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                                                <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0"><strong>@match.ReceiptItemName</strong></RadzenText>
                                                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Generic: @match.GenericName</RadzenText>
                                            </RadzenStack>
                                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                                <CurrencyDisplay Amount="@match.Price" />
                                                @if (match.IsTaxable)
                                                {
                                                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" IsPill="true" Variant="Variant.Flat"
                                                                 Text="HST" Style="font-size: 0.625rem;" />
                                                }
                                            </RadzenStack>
                                        </RadzenStack>

                                        @if (_resolvedMatches.Contains(match.ReceiptItemName))
                                        {
                                            <RadzenAlert AlertStyle="AlertStyle.Success" Variant="Variant.Flat" Size="AlertSize.Small"
                                                         ShowIcon="true" AllowClose="false">
                                                Resolved ✓
                                            </RadzenAlert>
                                        }
                                        else
                                        {
                                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.375rem">
                                                <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0"><strong>Found on:</strong></RadzenText>
                                                @foreach (var target in match.MatchingLists)
                                                {
                                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem"
                                                                 Style="padding: 0.375rem 0.5rem; border: 1px solid var(--rz-base-200); border-radius: 6px;">
                                                        <RadzenIcon Icon="list" Style="font-size: 1rem; color: var(--rz-primary);" />
                                                        <RadzenStack Orientation="Orientation.Vertical" Gap="0" Style="flex: 1;">
                                                            <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0"><strong>@target.ShoppingListTitle</strong></RadzenText>
                                                            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary rz-mb-0">Item: @target.ShoppingItemName</RadzenText>
                                                        </RadzenStack>
                                                        <RadzenButton Text="Check Off" Icon="check" Size="ButtonSize.ExtraSmall"
                                                                      ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                                      IsBusy="@_isResolvingMatch"
                                                                      Click="@(() => ResolveMatchAsync(match, target, toggleExisting: true))" />
                                                    </RadzenStack>
                                                }
                                                <RadzenButton Text="Add to Current List Instead" Icon="add" Size="ButtonSize.ExtraSmall"
                                                              ButtonStyle="ButtonStyle.Info" Variant="Variant.Outlined"
                                                              IsBusy="@_isResolvingMatch"
                                                              Click="@(() => AddToCurrentListAsync(match))"
                                                              Style="align-self: flex-start;" />
                                            </RadzenStack>
                                        }
                                    </RadzenStack>
                                </RadzenCard>
                            }
                        </RadzenStack>
                    </RadzenTabsItem>
                }
            </Tabs>
        </RadzenTabs>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End"
                     Gap="0.5rem" class="rz-pt-4"
                     Style="border-top: 1px solid var(--rz-base-200);">
            <RadzenButton Text="View Bill" Icon="receipt" Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Info"
                          Click="@(() => NavigateToBill(_result.BillId))" />
            <RadzenButton Text="Done" Icon="check" ButtonStyle="ButtonStyle.Primary"
                          Click="@(() => DialogService.Close(true))" />
        </RadzenStack>
    }
</RadzenStack>
