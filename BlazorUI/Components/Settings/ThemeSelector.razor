<RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" class="rz-p-sm-2">
    <RadzenLabel Text="Current theme" />
    <RadzenDropDown Name="ThemeDropDown" 
        TValue="string" 
        Value="@ThemeService.Theme" 
        ValueChanged="@ChangeTheme" 
        Data="@Themes.Free" 
        TextProperty=@nameof(Theme.Text) 
        ValueProperty=@nameof(Theme.Value)>
    </RadzenDropDown>
</RadzenStack>