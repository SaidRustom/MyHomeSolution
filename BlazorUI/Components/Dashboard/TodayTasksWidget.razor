@using BlazorUI.Models.Tasks

@if (_isLoading)
{
    <div class="widget-loading">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Small" />
    </div>
}
else
{
    <div class="tasks-widget">
        <div class="tasks-widget-header">
            <div class="tasks-widget-header-left">
                <div class="tasks-widget-icon">
                    <RadzenIcon Icon="task_alt" Style="font-size: 1.125rem; color: var(--rz-primary);" />
                </div>
                <span class="tasks-widget-title">Today's Tasks</span>
            </div>
            @if (_tasks.Count > 0)
            {
                <RadzenBadge BadgeStyle="@(_completedCount == _totalOccurrences ? BadgeStyle.Success : BadgeStyle.Primary)"
                             IsPill="true" Variant="Variant.Flat"
                             Text="@($"{_completedCount}/{_totalOccurrences}")"
                             Style="font-size: 0.7rem; font-weight: 700;" />
            }
        </div>

        @if (_totalOccurrences > 0)
        {
            <div class="tasks-progress-bar">
                <div class="tasks-progress-fill" style="width: @(_progressPercent.ToString("F0"))%;"></div>
            </div>
        }

        <div class="tasks-widget-body">
            @if (_tasks.Count == 0)
            {
                <div class="tasks-empty">
                    <RadzenIcon Icon="celebration" Style="font-size: 1.75rem; color: var(--rz-success);" />
                    <span class="tasks-empty-text">No tasks for today!</span>
                    <RadzenButton Text="View Scheduler" Icon="calendar_month" Variant="Variant.Text"
                                  ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.ExtraSmall"
                                  Click="@(() => NavigationManager.NavigateTo("/scheduler"))" />
                </div>
            }
            else
            {
                @foreach (var task in _tasks)
                {
                    @foreach (var occ in task.Occurrences)
                    {
                        <div class="task-item @(occ.Status == OccurrenceStatus.Completed ? "completed" : occ.Status == OccurrenceStatus.InProgress ? "in-progress" : "")">
                            <div class="task-item-priority" style="background: @GetPriorityColor(task.Priority);"></div>

                            <div class="task-item-content"
                                 @onclick="@(() => NavigationManager.NavigateTo($"/tasks/{task.TaskId}?occurrenceId={occ.Id}"))">
                                <span class="task-item-title @(occ.Status == OccurrenceStatus.Completed ? "done" : "")">@task.Title</span>
                                <span class="task-item-meta">
                                    @task.Category
                                    @if (task.EstimatedDurationMinutes.HasValue)
                                    {
                                        <text> · @(task.EstimatedDurationMinutes)m</text>
                                    }
                                </span>
                            </div>

                            <div class="task-item-actions">
                                @if (occ.Status == OccurrenceStatus.Pending)
                                {
                                    <button class="task-action-btn start" title="Start"
                                            @onclick="@(() => StartOccurrenceAsync(occ.Id))"
                                            @onclick:stopPropagation="true" disabled="@_isBusy">
                                        <RadzenIcon Icon="play_arrow" />
                                    </button>
                                    <button class="task-action-btn complete" title="Complete"
                                            @onclick="@(() => CompleteOccurrenceAsync(occ.Id))"
                                            @onclick:stopPropagation="true" disabled="@_isBusy">
                                        <RadzenIcon Icon="check" />
                                    </button>
                                }
                                else if (occ.Status == OccurrenceStatus.InProgress)
                                {
                                    <button class="task-action-btn complete" title="Complete"
                                            @onclick="@(() => CompleteOccurrenceAsync(occ.Id))"
                                            @onclick:stopPropagation="true" disabled="@_isBusy">
                                        <RadzenIcon Icon="check" />
                                    </button>
                                }
                                else if (occ.Status == OccurrenceStatus.Completed)
                                {
                                    <div class="task-done-check">
                                        <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); font-size: 1.25rem;" />
                                    </div>
                                }
                                else if (occ.Status == OccurrenceStatus.Overdue)
                                {
                                    <button class="task-action-btn complete" title="Complete"
                                            @onclick="@(() => CompleteOccurrenceAsync(occ.Id))"
                                            @onclick:stopPropagation="true" disabled="@_isBusy">
                                        <RadzenIcon Icon="check" />
                                    </button>
                                    <button class="task-action-btn skip" title="Skip"
                                            @onclick="@(() => SkipOccurrenceAsync(occ.Id))"
                                            @onclick:stopPropagation="true" disabled="@_isBusy">
                                        <RadzenIcon Icon="skip_next" />
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            }
        </div>

        <div class="tasks-widget-footer">
            <RadzenButton Text="All Tasks" Icon="arrow_forward" Variant="Variant.Text"
                          ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.ExtraSmall"
                          Click="@(() => NavigationManager.NavigateTo("/scheduler"))" />
        </div>
    </div>
}
